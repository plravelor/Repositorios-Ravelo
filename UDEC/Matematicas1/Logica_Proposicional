// ── QUIZ FUNCTIONS ────────────────────────────────────────────
function renderQuiz(){
  const c = document.getElementById('quiz-container');
  c.innerHTML = '';
  QS.forEach((q,i)=>{
    c.innerHTML += `<div class="quiz-q"><div class="quiz-q-num">Pregunta ${i+1} de ${QS.length}</div>
      <div class="quiz-q-text">${q.q}</div>
      <div class="quiz-opts">
        ${q.opts.map((opt,j)=>`<label class="quiz-opt" id="qo${i}_${j}" onclick="pickQ(${i},${j})">
          <input type="radio" name="q${i}" value="${j}"><span>${opt}</span></label>`).join('')}
      </div>
      <div class="q-fb" id="qfb${i}"></div></div>`;
  });
  loadQuizFromStorage();
}

function pickQ(qi, sel){
  quizAnswers[qi] = sel;
  for(let j=0;j<QS[qi].opts.length;j++){
    document.getElementById(`qo${qi}_${j}`).classList.toggle('sel',j===sel);
  }
  saveQuizToStorage();
}

function saveQuizToStorage(){
  try{
    localStorage.setItem(QUIZ_KEY, JSON.stringify(quizAnswers));
    document.getElementById('saved-badge').style.display='inline-flex';
  }catch(e){}
}

function loadQuizFromStorage(){
  try{
    const saved = localStorage.getItem(QUIZ_KEY);
    if(!saved) return;
    quizAnswers = JSON.parse(saved);
    Object.entries(quizAnswers).forEach(([qi,sel])=>{
      const el = document.getElementById(`qo${qi}_${sel}`);
      if(el){
        el.classList.add('sel');
        el.querySelector('input').checked = true;
      }
    });
    if(Object.keys(quizAnswers).length > 0)
      document.getElementById('saved-badge').style.display='inline-flex';
  }catch(e){}
}

function gradeQuiz(){
  if(quizGraded) return;
  if(Object.keys(quizAnswers).length < QS.length){
    toast('Faltan '+(QS.length-Object.keys(quizAnswers).length)+' preguntas');
    return;
  }
  quizGraded = true;
  document.getElementById('quiz-btn').disabled = true;
  let correct = 0;
  QS.forEach((q,i)=>{
    const sel = quizAnswers[i];
    const ok = sel === q.c;
    if(ok) correct++;
    for(let j=0;j<q.opts.length;j++){
      const el = document.getElementById(`qo${i}_${j}`);
      el.querySelector('input').disabled = true;
      if(j===q.c) el.classList.add('ok');
      else if(j===sel&&!ok) el.classList.add('ko');
    }
    const fb = document.getElementById(`qfb${i}`);
    const msg = ok ? q.ok : (q.ko[sel]||('✗ La opción correcta era la '+(q.c+1)+'. '+q.ok));
    fb.className = 'q-fb '+(ok?'ok':'ko');
    fb.innerHTML = msg;
    fb.style.display = 'block';
  });
  const nota = (correct*5/QS.length).toFixed(1);
  const box = document.getElementById('score-box');
  box.style.display = 'block';
  document.getElementById('score-num').textContent = nota;
  document.getElementById('score-fill').style.width = (correct/QS.length*100)+'%';
  const msgs = [
    'Hay conceptos clave para repasar. Revisa las pestañas de Conectivos y Condicional antes de hacer los ejercicios para casa.',
    'Vas bien. Algunos conceptos para consolidar — los ejercicios en casa te ayudarán.',
    'Buen desempeño. Revisa las preguntas que fallaste y refuerza con el Nivel C y D de los ejercicios.',
    'Muy buen dominio del tema. Los ejercicios de casa te llevarán al siguiente nivel.',
    '¡Excelente! Puedes explicarle estos conceptos a un compañero.'
  ];
  document.getElementById('score-msg').textContent = msgs[Math.min(Math.floor(correct/(QS.length/5)), msgs.length-1)];
  box.scrollIntoView({behavior:'smooth',block:'center'});
}

function resetQuiz(){
  quizAnswers = {};
  quizGraded = false;
  try{ localStorage.removeItem(QUIZ_KEY); }catch(e){}
  document.querySelectorAll('.quiz-opt').forEach(o=>{
    o.classList.remove('sel','ok','ko');
    const inp = o.querySelector('input');
    if(inp){inp.disabled=false;inp.checked=false;}
  });
  document.querySelectorAll('.q-fb').forEach(f=>f.style.display='none');
  document.getElementById('score-box').style.display='none';
  document.getElementById('quiz-btn').disabled=false;
  document.getElementById('saved-badge').style.display='none';
  toast('Quiz reiniciado');
}

