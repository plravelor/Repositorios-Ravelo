// ── QUIZ DATA ─────────────────────────────────────────────────
const QS = [
  {q:'¿Cuál de estas es una proposición lógica?',
   opts:['¿Los jóvenes de Facatativá duermen bien?','La temperatura media en Facatativá en enero es 9°C.','¡Estudia lógica antes del parcial!','Ojalá que haya curvas en la calificación.'],c:1,
