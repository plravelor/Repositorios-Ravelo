function buildHW(containerId, data, levelColor){
  const c = document.getElementById(containerId);
  if(!c) return;
  data.forEach((ex,i)=>{
    const d = document.createElement('div');
    d.className = 'hw-ex';
    const optsHtml = ex.opts.map((opt,j)=>`<div class="hw-ex-opt" id="hw-${containerId}-${i}-${j}" onclick="pickHW('${containerId}',${i},${j},${ex.c})">${String.fromCharCode(97+j)}) ${opt}</div>`).join('');
    d.innerHTML=`<div class="hw-ex-q">${ex.q}</div>
      <div class="hw-ex-opts">${optsHtml}</div>
      <div class="hw-ex-reveal" style="background:rgba(255,255,255,.04);border:1px solid var(--border2);">${ex.why}</div>`;
    c.appendChild(d);
  });
}

function pickHW(level, qi, sel, correct){
  // mark selected
  for(let j=0;j<10;j++){
    const el=document.getElementById(`hw-${level}-${qi}-${j}`);
    if(!el)break;
    el.classList.remove('hw-sel','hw-ok','hw-ko');
  }
  const selEl=document.getElementById(`hw-${level}-${qi}-${sel}`);
  const corEl=document.getElementById(`hw-${level}-${qi}-${correct}`);
  if(selEl) selEl.classList.add(sel===correct?'hw-ok':'hw-ko');
  if(sel!==correct && corEl) corEl.classList.add('hw-ok');
  // show reveal
  const parent=selEl?selEl.closest('.hw-ex'):null;
  if(parent) parent.classList.add('open');
}

