   opts:["Es incorrecta: mezclar preguntas descriptivas con preguntas sobre sentimientos viola el principio de no-directividad.","Es metodológicamente adecuada: va de preguntas descriptivas a estructurales y avanza hacia la experiencia emocional, respetando la progresión que permite construir confianza antes de abordar el tema sensible.","El error está en empezar por 'un día normal': al no mencionar el acoso directamente, se arriesga a no llegar al tema.","Es adecuada para semiestructurada pero no para en profundidad: Robles especifica que la en profundidad debe empezar directamente con el tema central."],
   correct:1,
   fb:["Error: Robles no prohíbe mezclar niveles de preguntas. Al contrario, la progresión de descriptivo a emocional es una estrategia que construye confianza antes de llegar a lo sensible.","Correcta: la secuencia respeta el principio de progresión de Robles — partir de lo cotidiano (descriptivo) hacia lo que le resulta difícil (estructural) y luego hacia la experiencia vivida (contraste con 'cómo se sintió').","Error de estrategia: en entrevistas sobre temas sensibles como el acoso, ir directo al tema en la primera pregunta puede generar cierre defensivo. Empezar por lo cotidiano es una estrategia relacional justificada.","Error: Robles no establece esa regla. La entrevista en profundidad puede y debe comenzar desde donde el participante se sienta más cómodo para avanzar progresivamente."]},
];

// ═══════════════════════════════════════════════
// QUIZ LOGIC
// ═══════════════════════════════════════════════
const STORE_KEY='quiz_s9_udec_v2';
let quizInitialized=false;

function initQuiz(){
  if(quizInitialized) return;
  quizInitialized=true;
  const saved=localStorage.getItem(STORE_KEY);
  if(saved){
    try{
      const data=JSON.parse(saved);
      showSavedResult(data);
    }catch(e){renderQuizForm()}
  } else {
    renderQuizForm();
  }
}

function showSavedResult(data){
  const pct=(data.score/QUIZ.length*100).toFixed(0);
  const nota=(data.score/QUIZ.length*5).toFixed(2);
  const fecha=new Date(data.ts).toLocaleDateString('es-CO',{day:'2-digit',month:'short',year:'numeric',hour:'2-digit',minute:'2-digit'});

  let html=`<div class="quiz-saved-note" role="alert">📌 Primera nota guardada el ${fecha} — el puntaje no cambia al recargar la página.</div>
  <div class="quiz-score-banner" aria-live="polite">
    <div class="quiz-score-big">${data.score}/${QUIZ.length}</div>
    <div class="quiz-score-lbl">${pct}% de preguntas correctas</div>
    <div class="quiz-score-nota">Nota: ${nota} / 5.0</div>
  </div>`;

  // Render each question with answer revealed
  QUIZ.forEach((q,i)=>{
    const chosen=data.answers[i];
    const correct=q.correct;
    html+=`<div class="quiz-qcard">
      <div class="quiz-qhdr">
        <div class="quiz-qnum" aria-hidden="true">${i+1}</div>
        <div class="quiz-qtxt">${q.q}</div>
      </div>
      <div class="quiz-opts">`;
    q.opts.forEach((o,j)=>{
      let cls='quiz-opt';
      if(j===correct) cls+=' correct';
      else if(j===chosen&&chosen!==correct) cls+=' wrong';
      html+=`<div class="${cls}" aria-label="Opción ${String.fromCharCode(65+j)}${j===correct?' (correcta)':''}${j===chosen&&chosen!==correct?' (tu respuesta, incorrecta)':''}">${String.fromCharCode(97+j)}) ${o}</div>`;
    });
    html+=`</div>
      <div class="quiz-feedback vis" aria-live="polite">
        <div class="feedback-ok">${chosen===correct?'✔ Correcta':'✘ Respuesta incorrecta'}</div>
        <div class="feedback-exp">${q.fb[chosen!==undefined?chosen:correct]}</div>
      </div></div>`;
  });

  document.getElementById('quiz-area').innerHTML=html;
  document.getElementById('quiz-saved-display').innerHTML='';
}

function renderQuizForm(){
  let html='<form id="quiz-form" onsubmit="submitQuiz(event)" novalidate>';
  QUIZ.forEach((q,i)=>{
    html+=`<div class="quiz-qcard" id="qc${i}">
      <div class="quiz-qhdr">
        <div class="quiz-qnum" aria-hidden="true">${i+1}</div>
        <div class="quiz-qtxt">${q.q}</div>
      </div>
      <div class="quiz-opts" role="group" aria-labelledby="ql${i}">
        <span id="ql${i}" class="sr-only">Pregunta ${i+1}: ${q.q}</span>`;
    q.opts.forEach((o,j)=>{
      html+=`<label class="quiz-opt" for="q${i}o${j}">
        <input type="radio" name="q${i}" id="q${i}o${j}" value="${j}" required>
        ${String.fromCharCode(97+j)}) ${o}
      </label>`;
    });
    html+=`</div>
      <div class="quiz-feedback" id="fb${i}" aria-live="polite"></div>
    </div>`;
  });
  html+=`<button type="submit" class="btn-p" style="margin-top:8px">Ver mi nota y retroalimentación</button></form>`;
  document.getElementById('quiz-area').innerHTML=html;

  // Live option highlighting
  QUIZ.forEach((_,i)=>{
    document.querySelectorAll(`input[name="q${i}"]`).forEach(r=>{
      r.addEventListener('change',()=>{
        document.querySelectorAll(`input[name="q${i}"]`).forEach(x=>{
          x.parentElement.style.borderColor='';
          x.parentElement.style.background='';
        });
        r.parentElement.style.borderColor='var(--v)';
        r.parentElement.style.background='var(--vc)';
      });
    });
  });
}

function submitQuiz(e){
  e.preventDefault();
  let score=0; const answers=[];
  let allAnswered=true;
  QUIZ.forEach((q,i)=>{
    const sel=document.querySelector(`input[name="q${i}"]:checked`);
    if(!sel){allAnswered=false;document.getElementById('qc'+i).scrollIntoView({behavior:'smooth'});return}
    const chosen=parseInt(sel.value);
    answers.push(chosen);
    const correct=q.correct;
    if(chosen===correct) score++;
    // Show feedback
    document.querySelectorAll(`input[name="q${i}"]`).forEach((r,j)=>{
      const lbl=r.parentElement;
      lbl.classList.remove('correct','wrong','correct-missed');
      if(j===correct) lbl.classList.add('correct');
      else if(j===chosen&&chosen!==correct) lbl.classList.add('wrong');
      r.disabled=true;
    });
    const fb=document.getElementById('fb'+i);
    fb.innerHTML=`<div class="feedback-ok">${chosen===correct?'✔ Correcta':'✘ Incorrecta — la respuesta correcta es la opción ${String.fromCharCode(97+correct)}'}</div><div class="feedback-exp">${q.fb[chosen]}</div>`;
    fb.classList.add('vis');
  });
  if(!allAnswered){alert('Responde todas las preguntas antes de ver la nota.');return}

  const nota=(score/QUIZ.length*5).toFixed(2);
  const pct=(score/QUIZ.length*100).toFixed(0);
  const scoreBanner=document.createElement('div');
  scoreBanner.className='quiz-score-banner';
  scoreBanner.setAttribute('role','alert');
  scoreBanner.setAttribute('aria-live','assertive');
  scoreBanner.innerHTML=`<div class="quiz-score-big">${score}/${QUIZ.length}</div>
    <div class="quiz-score-lbl">${pct}% de preguntas correctas</div>
    <div class="quiz-score-nota">Nota: ${nota} / 5.0</div>
    <div style="font-family:system-ui,sans-serif;font-size:12px;opacity:.75;margin-top:8px">📌 Este puntaje queda guardado en tu dispositivo</div>`;

  const form=document.getElementById('quiz-form');
  const btn=form.querySelector('button[type="submit"]');
  btn.parentElement.insertBefore(scoreBanner, btn);
  btn.remove();

  // Disable all
  document.querySelectorAll('#quiz-form input[type="radio"]').forEach(r=>r.disabled=true);

  // Save to localStorage (first time only)
  if(!localStorage.getItem(STORE_KEY)){
    localStorage.setItem(STORE_KEY,JSON.stringify({score,total:QUIZ.length,answers,ts:Date.now()}));
  }
  scoreBanner.scrollIntoView({behavior:'smooth'});
}
</script>
</body>
</html>
