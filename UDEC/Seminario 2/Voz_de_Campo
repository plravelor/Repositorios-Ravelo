<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Voz de Campo — La entrevista en profundidad · Sesión 9</title>
<style>
/* ═══ VARIABLES ═══ */
:root{
  --v:#1a5c3a;--vc:#e8f5ee;--vm:#2d7a52;
  --a:#1a3a5c;--ac:#e4edf8;
  --o:#7a5c00;--oc:#fef5e0;
  --p:#3a1a5c;--pc:#f0e8f8;
  --r:#6b1a1a;--rc:#fdeaea;
  --g:#2c2c2a;--gs:#f6f5f1;--bd:#ccc9c2;
  --fondo:#edeae4;
  --focus:#0055cc;
}
*{box-sizing:border-box;margin:0;padding:0}

/* ═══ SKIP LINK ═══ */
.skip{position:absolute;left:-10000px;top:auto;width:1px;height:1px;overflow:hidden;background:#fff;color:var(--v);font-weight:700;padding:12px 20px;font-size:14px;z-index:9999;border:2px solid var(--v)}
.skip:focus{left:8px;top:8px;width:auto;height:auto;overflow:visible}

/* ═══ LIVE REGION ═══ */
#live{position:absolute;left:-10000px}

/* ═══ BODY ═══ */
body{font-family:Georgia,'Times New Roman',serif;font-size:15px;line-height:1.75;color:var(--g);background:var(--fondo);min-height:100vh}

/* ═══ HEADER ═══ */
header{background:var(--v);color:#fff;padding:14px 20px}
header h1{font-family:system-ui,sans-serif;font-size:17px;font-weight:700}
header p{font-size:11px;opacity:.82;margin-top:2px;font-family:system-ui,sans-serif}

/* ═══ NAV TABS ═══ */
nav[role="tablist"]{
  background:#fff;border-bottom:3px solid var(--vc);
  overflow-x:auto;display:flex;
  position:sticky;top:0;z-index:100;
  box-shadow:0 2px 6px rgba(0,0,0,.08)
}
nav[role="tablist"] button{
  flex-shrink:0;padding:11px 14px;font-size:12px;
  font-family:system-ui,sans-serif;font-weight:600;
  border:none;background:none;cursor:pointer;
  color:#777;border-bottom:3px solid transparent;
  margin-bottom:-3px;transition:all .2s;white-space:nowrap;
  line-height:1.3
}
nav[role="tablist"] button:focus{outline:3px solid var(--focus);outline-offset:-3px;background:#e8efff}
nav[role="tablist"] button[aria-selected="true"]{color:var(--v);border-bottom-color:var(--v);background:var(--vc)}
nav[role="tablist"] button:hover:not([aria-selected="true"]){background:#f5f4f0;color:var(--g)}

/* ═══ MAIN ═══ */
main{max-width:780px;margin:0 auto;padding:22px 18px 80px}
section[role="tabpanel"]{display:none}
section[role="tabpanel"].vis{display:block}
section[role="tabpanel"]:focus{outline:none}

/* ═══ BADGES EN/CASA ═══ */
.en-clase,.en-casa{display:inline-flex;align-items:center;gap:5px;font-family:system-ui,sans-serif;font-size:11px;font-weight:700;padding:3px 10px;border-radius:10px;letter-spacing:.03em;margin-bottom:12px}
.en-clase{background:var(--vc);color:var(--v);border:1.5px solid var(--vm)}
.en-casa{background:var(--pc);color:var(--p);border:1.5px solid var(--p)}

/* ═══ TYPOGRAPHY ═══ */
h2{font-family:system-ui,sans-serif;font-size:20px;font-weight:700;color:var(--v);margin-bottom:12px;padding-bottom:8px;border-bottom:2px solid var(--vc)}
h3{font-family:system-ui,sans-serif;font-size:16px;font-weight:700;color:var(--v);margin:20px 0 8px}
h4{font-family:system-ui,sans-serif;font-size:14px;font-weight:700;color:var(--g);margin:14px 0 6px}
p{margin-bottom:9px;font-size:15px}
ul,ol{padding-left:22px;margin-bottom:9px}
li{margin-bottom:5px;font-size:15px}
strong{font-weight:700}
em{font-style:italic}

/* ═══ CARDS ═══ */
.card{background:#fff;border-radius:10px;padding:18px 20px;margin-bottom:16px;border:1px solid var(--bd)}
.card-v{border-left:5px solid var(--v)}
.card-a{border-left:5px solid var(--a)}
.card-o{border-left:5px solid var(--o)}
.card-p{border-left:5px solid var(--p)}
.card-r{border-left:5px solid var(--r)}

/* ═══ INTRO BANNER ═══ */
.banner{background:var(--v);color:#fff;border-radius:10px;padding:16px 20px;margin-bottom:20px;font-size:15px;line-height:1.7}
.banner strong{color:#b8f0d0}

/* ═══ ACCORDION ═══ */
.acorde{background:#fff;border-radius:10px;margin-bottom:10px;border:1px solid var(--bd);overflow:hidden}
.acorde-btn{
  width:100%;text-align:left;padding:14px 18px;
  background:var(--gs);border:none;cursor:pointer;
  display:flex;align-items:flex-start;gap:12px;
  font-family:system-ui,sans-serif;font-size:14px;font-weight:700;
  color:var(--g);transition:background .2s
}
.acorde-btn:hover{background:var(--vc)}
.acorde-btn:focus{outline:3px solid var(--focus);outline-offset:-3px}
.acorde-ico{font-size:20px;flex-shrink:0;margin-top:1px}
.acorde-tit{flex:1;line-height:1.4}
.acorde-sub{font-size:12px;font-weight:400;color:#888;display:block;margin-top:2px}
.acorde-chev{flex-shrink:0;font-size:13px;color:var(--vm);transition:transform .25s;margin-top:3px}
.acorde-btn[aria-expanded="true"] .acorde-chev{transform:rotate(180deg)}
.acorde-btn[aria-expanded="true"]{background:var(--vc);color:var(--v)}
.acorde-body{display:none;padding:14px 18px 18px;border-top:1px solid var(--vc)}
.acorde-body.open{display:block}

/* ═══ DILEMA ═══ */
.dilema{background:#fff;border-radius:10px;margin-bottom:12px;border:1.5px solid var(--bd);overflow:hidden}
.dil-head{padding:14px 18px;background:var(--gs);display:flex;align-items:flex-start;gap:12px}
.dil-num{background:var(--v);color:#fff;font-family:system-ui,sans-serif;font-size:12px;font-weight:700;min-width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.dil-txt{flex:1;font-size:14px}
.btn-rev{background:var(--vc);color:var(--v);border:2px solid var(--v);padding:6px 14px;border-radius:20px;font-family:system-ui,sans-serif;font-size:12px;font-weight:700;cursor:pointer;flex-shrink:0;margin-top:2px;transition:all .2s}
.btn-rev:hover{background:var(--v);color:#fff}
.btn-rev:focus{outline:3px solid var(--focus);outline-offset:2px}
.dil-tension{padding:14px 18px;background:var(--rc);border-top:1px solid #e8c0c0;display:none}
.dil-tension.vis{display:block}
.dil-lbl{font-family:system-ui,sans-serif;font-size:11px;font-weight:700;color:var(--r);text-transform:uppercase;letter-spacing:.05em;margin-bottom:6px}

/* ═══ TABLA TIPOLOGÍA ═══ */
.tipo-grid{display:grid;grid-template-columns:1fr;gap:12px;margin-bottom:16px}
@media(min-width:600px){.tipo-grid{grid-template-columns:1fr 1fr}}
.tipo-card{background:#fff;border-radius:10px;padding:16px;border:1.5px solid var(--bd);border-top:4px solid}
.tc-en{border-top-color:var(--v)}.tc-semi{border-top-color:var(--vm)}.tc-prof{border-top-color:var(--a)}
.tc-foc{border-top-color:var(--o)}.tc-nod{border-top-color:var(--p)}.tc-grp{border-top-color:#5c1a1a}
.tipo-card h4{font-size:14px;margin:0 0 6px}
.tc-en h4{color:var(--v)}.tc-semi h4{color:var(--vm)}.tc-prof h4{color:var(--a)}
.tc-foc h4{color:var(--o)}.tc-nod h4{color:var(--p)}.tc-grp h4{color:#5c1a1a}
.tipo-card p{font-size:13px}
.tag-mini{display:inline-block;font-family:system-ui,sans-serif;font-size:11px;font-weight:700;padding:2px 8px;border-radius:8px;margin:2px 2px 2px 0}
.tag-ok{background:var(--vc);color:var(--v)}.tag-no{background:var(--rc);color:var(--r)}
.tag-amb{background:var(--oc);color:var(--o)}

/* ═══ NIVELES DE PREGUNTAS ═══ */
.nivel-pregunta{background:#fff;border-radius:10px;margin-bottom:10px;overflow:hidden;border:1px solid var(--bd)}
.niv-hdr{padding:12px 18px;display:flex;align-items:center;gap:12px;cursor:pointer}
.niv-num{font-family:system-ui,sans-serif;font-size:20px;font-weight:700;min-width:32px;text-align:center}
.niv-body{padding:0 18px;max-height:0;overflow:hidden;transition:max-height .3s ease,padding .2s}
.niv-body.open{max-height:600px;padding:12px 18px 18px}

/* ═══ FORM ═══ */
.form-g{margin-bottom:14px}
.form-g label{display:block;font-family:system-ui,sans-serif;font-size:13px;font-weight:700;color:var(--g);margin-bottom:5px}
.form-g textarea,.form-g input,.form-g select{
  width:100%;padding:10px 12px;border:2px solid var(--bd);
  border-radius:8px;font-size:14px;font-family:Georgia,serif;
  line-height:1.5;resize:vertical;color:var(--g);background:#fff;transition:border-color .2s
}
.form-g textarea:focus,.form-g input:focus,.form-g select:focus{outline:none;border-color:var(--focus);box-shadow:0 0 0 3px rgba(0,85,204,.18)}
.form-g .hint{font-family:system-ui,sans-serif;font-size:12px;color:#888;margin-top:3px;font-style:italic}

/* ═══ BUTTONS ═══ */
.btn-p{background:var(--v);color:#fff;border:none;padding:12px 22px;border-radius:8px;font-family:system-ui,sans-serif;font-size:14px;font-weight:700;cursor:pointer;transition:background .2s;width:100%;margin-top:8px}
.btn-p:hover{background:var(--vm)}
.btn-p:focus{outline:3px solid var(--focus);outline-offset:2px}
.btn-s{background:#fff;color:var(--v);border:2px solid var(--v);padding:10px 20px;border-radius:8px;font-family:system-ui,sans-serif;font-size:13px;font-weight:700;cursor:pointer;margin-top:8px;transition:all .2s}
.btn-s:hover{background:var(--vc)}
.btn-s:focus{outline:3px solid var(--focus);outline-offset:2px}

/* ═══ NOTA ═══ */
.nota{background:var(--oc);border-left:4px solid var(--o);border-radius:0 8px 8px 0;padding:12px 16px;margin:10px 0;font-size:14px}
.nota .nl{font-family:system-ui,sans-serif;font-size:11px;font-weight:700;color:var(--o);text-transform:uppercase;letter-spacing:.05em;margin-bottom:5px}

/* ═══ QUIZ ═══ */
.quiz-qcard{background:#fff;border-radius:10px;border:1px solid var(--bd);overflow:hidden;margin-bottom:14px}
.quiz-qhdr{padding:14px 18px;background:var(--gs);display:flex;align-items:flex-start;gap:12px}
.quiz-qnum{background:var(--v);color:#fff;font-family:system-ui,sans-serif;font-size:12px;font-weight:700;min-width:28px;height:28px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}
.quiz-qtxt{font-size:14px;flex:1;line-height:1.6}
.quiz-opts{padding:12px 18px 16px}
.quiz-opt{display:block;padding:9px 14px;margin-bottom:8px;border:2px solid var(--bd);border-radius:8px;cursor:pointer;font-size:14px;font-family:Georgia,serif;transition:all .2s;background:#fff}
.quiz-opt:hover{border-color:var(--vm);background:var(--vc)}
.quiz-opt:focus-within{outline:3px solid var(--focus);outline-offset:2px}
.quiz-opt input[type="radio"]{margin-right:10px;accent-color:var(--v)}
.quiz-opt.correct{background:#e8f5ee;border-color:var(--v);color:var(--v)}
.quiz-opt.wrong{background:var(--rc);border-color:var(--r);color:var(--r)}
.quiz-opt.correct-missed{background:#fff3cd;border-color:#d4a900;color:#7a5500}
.quiz-feedback{display:none;padding:10px 18px 14px;font-size:13px;font-family:system-ui,sans-serif}
.quiz-feedback.vis{display:block}
.feedback-ok{color:var(--v);font-weight:700}
.feedback-exp{color:var(--g);margin-top:4px}

.quiz-score-banner{background:var(--v);color:#fff;border-radius:12px;padding:22px;text-align:center;margin-bottom:20px}
.quiz-score-big{font-size:52px;font-weight:700;font-family:system-ui,sans-serif;line-height:1}
.quiz-score-lbl{font-size:14px;opacity:.85;margin-top:4px;font-family:system-ui,sans-serif}
.quiz-score-nota{font-size:24px;font-weight:700;font-family:system-ui,sans-serif;margin-top:8px;opacity:.9}
.quiz-saved-note{background:var(--oc);border-radius:8px;padding:12px 16px;text-align:center;margin-bottom:16px;font-family:system-ui,sans-serif;font-size:13px;color:var(--o);font-weight:600}

/* ═══ STEP PROTOCOL ═══ */
.paso{display:flex;gap:12px;margin-bottom:12px;align-items:flex-start}
.paso-n{background:var(--vm);color:#fff;font-size:12px;font-weight:700;font-family:system-ui,sans-serif;min-width:26px;height:26px;border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;margin-top:2px}

/* ═══ READING CARDS ═══ */
.lect-card{border:1.5px solid var(--bd);border-radius:10px;overflow:hidden;margin-bottom:14px}
.lect-hdr{padding:11px 16px;font-family:system-ui,sans-serif;font-size:13px;font-weight:700}
.lect-hdr.a{background:var(--ac);color:var(--a)}.lect-hdr.b{background:var(--pc);color:var(--p)}
.lect-body{padding:14px 16px}
.lect-body h5{font-family:system-ui,sans-serif;font-size:13px;font-weight:700;color:var(--g);margin:10px 0 5px}
.lect-body h5:first-child{margin-top:0}

/* ═══ PROGRESS TEXT ═══ */
.prog-txt{font-family:system-ui,sans-serif;font-size:12px;color:#999;text-align:right;margin-bottom:8px}
hr{border:none;border-top:1px solid var(--bd);margin:22px 0}
</style>
