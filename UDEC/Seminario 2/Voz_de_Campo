function diagnosticar(){
  const tipo=document.getElementById('tipo-ent').value;
  const verbo=document.getElementById('verbo-ent').value.toLowerCase().trim();
  const preg=document.getElementById('preg1').value.trim();
  if(!tipo||!verbo){alert('Completa el tipo de entrevista y el verbo antes de continuar.');return}

  let titulo='', texto='', pregunta='';
  const positivistas=['determinar','establecer','medir','identificar','calcular','comprobar','verificar'];
  const cuali=['comprender','explorar','describir','interpretar','construir','generar','visibilizar'];
  const isPositivista=positivistas.some(v=>verbo.includes(v));
  const isCuali=cuali.some(v=>verbo.includes(v));
  const esProf=tipo.includes('profundidad');
  const esSemi=tipo.includes('semi');
  const esEstruct=tipo.includes('estructurada');

  if(isPositivista && esProf){
    titulo='⚠ Tensión paradigmática detectada';
    texto='El verbo "'+verbo+'" corresponde a una lógica positivista (busca determinar, establecer, medir). La entrevista en profundidad, en cambio, busca comprender el significado desde el participante. El tipo de entrevista no puede producir lo que el verbo promete. Revisa los verbos de tus objetivos (sesión 6) o cambia a una técnica más coherente con tu paradigma.';
    pregunta='Pregunta para reflexionar: ¿Qué tipo de conocimiento esperas producir con esta entrevista?';
  } else if(isCuali && esProf){
    titulo='✔ Coherencia paradigmática';
    texto='El verbo "'+verbo+'" es coherente con la entrevista en profundidad. Ambos responden a la lógica interpretativa: no se busca capturar hechos sino construir comprensión desde la perspectiva del participante.';
    pregunta='Ahora verifica: ¿tu guía de entrevista tiene preguntas fijas numeradas, o tiene un propósito y herramientas de relanzamiento?';
  } else if(isCuali && esEstruct){
    titulo='⚠ Incoherencia de técnica con paradigma';
    texto='El verbo "'+verbo+'" apunta a una epistemología interpretativa, pero la entrevista estructurada cierra el espacio que ese tipo de comprensión exige. Las preguntas fijas no permiten que el participante lleve la conversación a donde le sea significativo.';
    pregunta='¿Por qué elegiste la entrevista estructurada? ¿Fue por comparabilidad o por facilidad de aplicación? ¿Hay una razón epistemológica?';
  } else if(isPositivista && esSemi){
    titulo='Coherencia parcial';
    texto='El verbo "'+verbo+'" y la entrevista semiestructurada son más compatibles que la combinación anterior. Sin embargo, si el objetivo real es determinar o establecer algo, considera si una entrevista es la técnica más adecuada o si un instrumento estandarizado sirve mejor tu propósito.';
    pregunta='¿Qué harás con la información que emerja más allá de tus preguntas predefinidas?';
  } else {
    titulo='Diagnóstico en proceso';
    texto='Con la información ingresada, el diagnóstico es ambiguo. Revisa el módulo 2 (tipología) y el módulo de verbos (sesión 6) para identificar la coherencia entre lo que prometes hacer y la técnica que elegiste.';
    pregunta='¿Qué tipo de conocimiento quieres producir sobre tu fenómeno? ¿Quieres describir, comprender, medir o transformar?';
  }

  // Analizar la primera pregunta
  if(preg){
    const cerradas=['¿cuántas','¿cuántos','¿qué tanto','¿ha','¿usa','¿tiene'];
    const abiertas=['cuénteme','descríbame','cómo fue','qué pasó','qué significa'];
    const esCerrada=cerradas.some(p=>preg.toLowerCase().includes(p));
    const esAbierta=abiertas.some(p=>preg.toLowerCase().includes(p));
    if(esCerrada&&esProf) texto+=' Además, tu primera pregunta ("'+preg.slice(0,60)+'...") parece cerrada — no invita a la narración sino a una respuesta puntual.';
    else if(esAbierta) texto+=' Tu primera pregunta invita a narrar, lo cual es un buen punto de partida.';
  }

  document.getElementById('diag-titulo').textContent=titulo;
  document.getElementById('diag-texto').textContent=texto;
  document.getElementById('diag-pregunta').textContent=pregunta;
  document.getElementById('diag-result').style.display='block';
  document.getElementById('diag-result').scrollIntoView({behavior:'smooth'});
}

