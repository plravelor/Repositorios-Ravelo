  document.getElementById('expmod').classList.add('open');
}
function closeExp(){document.getElementById('expmod').classList.remove('open');}
function copyExp(){
  const t=document.getElementById('etxt').textContent;
  navigator.clipboard.writeText(t).then(()=>{
    const btn=event.target;const o=btn.textContent;btn.textContent='✅ Copiado';setTimeout(()=>{btn.textContent=o},2000);
  });
}
function dlExp(){
  const t=buildExp();const blob=new Blob([t],{type:'text/plain;charset=utf-8'});
  const a=document.createElement('a');a.href=URL.createObjectURL(blob);a.download='anteproyecto_investigacion.txt';a.click();
}

