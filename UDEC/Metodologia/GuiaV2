function restoreSession(){
  loadST();
  FIELDS.forEach(lf);CHECKS.forEach(lc);
  if(ST.enf){const c=document.querySelector('.ec:nth-child('+({cuanti:1,cuali:2,mixto:3}[ST.enf]||1)+')');if(c)c.classList.add('sel');}
  if(ST.par){const idx={pospositivista:0,interpretativo:1,critico:2,pragmatico:3}[ST.par];const c=document.querySelectorAll('.pc')[idx];if(c)c.classList.add('sel');}
  if(ST.alc){const r=document.querySelector(`input[name="alc"][value="${ST.alc}"]`);if(r){r.checked=true;r.closest('.oi').classList.add('sel');}}
  if(ST.mc){const cards=document.querySelectorAll('.mc');const types=['fenomenologia','teoria-fundamentada','etnografia','iap','narrativa','estudio-caso'];const idx=types.indexOf(ST.mc);if(cards[idx])cards[idx].classList.add('sel');}
  applyCV();
  document.querySelectorAll('input[name="pto"]').forEach(r=>{if(r.value===ST.pto){r.checked=true;r.closest('.oi').classList.add('sel');}});
  goT(ST.ct||0);
  document.getElementById('sr').style.display='none';
}

function resetAll(){
  if(!confirm('¿Estás seguro/a? Se perderá todo el progreso guardado.'))return;
  Object.keys(localStorage).filter(k=>k.startsWith(NS)).forEach(k=>localStorage.removeItem(k));
  ST={ct:0,done:[],enf:'',par:'',alc:'',mc:'',pto:''};
  location.reload();
}

/* === INIT === */
function init(){
  buildTabs();checkSR();
  // Attach radio listeners for M0 diagnosis point selection
  document.querySelectorAll('input[name="pto"]').forEach(function(r){
    r.addEventListener('change',function(){showDV(r.value);});
  });
  document.querySelectorAll('.oi').forEach(item=>{
    const inp=item.querySelector('input');if(!inp)return;
    inp.addEventListener('change',()=>{
      if(inp.type==='radio')document.querySelectorAll(`input[name="${inp.name}"]`).forEach(i=>i.closest('.oi').classList.remove('sel'));
      if(inp.checked)item.classList.add('sel');else item.classList.remove('sel');
    });
    if(inp.checked)item.classList.add('sel');
  });
  updProg();
}
window.addEventListener('DOMContentLoaded',init);
