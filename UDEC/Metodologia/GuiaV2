/* === M6 HIPÓTESIS === */
function evalHip(){
  const hip=document.getElementById('m6-hip');if(!hip)return;
  const v=hip.value.trim();const d=document.getElementById('m6he');
  if(!v){d.innerHTML='';return;}
  const issues=[],ok=[];
  if(v.endsWith('?'))issues.push('Una hipótesis es una afirmación, no una pregunta.');
  else ok.push('Tiene forma declarativa (afirmación).');
  const rw=['relación','diferencia','mayor','menor','efecto','influye','predice','asocia','correlación','significativa'];
  if(!rw.some(w=>v.toLowerCase().includes(w)))issues.push('Debería indicar algún tipo de relación o diferencia entre variables.');
  else ok.push('Menciona una relación entre variables.');
  if(v.length>200)issues.push('La hipótesis es muy extensa. Idealmente no supera las 60-80 palabras.');
  d.innerHTML=(issues.length?mkAl('wn','⚠️','Aspectos a revisar',issues.map(i=>'• '+i).join('<br>')):'')+(ok.length?mkAl('ok','✅','Aspectos positivos',ok.map(o=>'• '+o).join('<br>')):'');
}

