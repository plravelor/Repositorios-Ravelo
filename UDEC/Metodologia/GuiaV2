let _lastPrompt='';
function showPrompt(divId,texto){
  _lastPrompt=texto;
  const d=document.getElementById(divId);d.style.display='block';
  const esc=texto.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\n/g,'<br>');
  d.innerHTML='<div class="pb-box">'
    +'<div class="pb-h"><span>&#128203; Copia este prompt y pégalo en Claude, ChatGPT u otra IA</span>'
    +'<button id="cp-'+divId+'" style="background:rgba(255,255,255,.2);color:white;border:none;cursor:pointer;padding:4px 10px;border-radius:4px;font-size:12px">Copiar</button>'
    +'</div><div class="pb-b" style="white-space:pre-wrap">'+esc+'</div></div>';
  document.getElementById('cp-'+divId).onclick=function(){cpPrompt(this,texto);};
