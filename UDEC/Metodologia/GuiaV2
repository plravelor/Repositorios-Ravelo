<script>
/* === STATE === */
const NS='inv_';
let ST={ct:0,done:[],enf:'',par:'',alc:'',mc:'',pto:''};

function lg(k){try{return localStorage.getItem(NS+k)}catch(e){return null}}
function ls(k,v){try{localStorage.setItem(NS+k,v)}catch(e){}}

function loadST(){const s=lg('_st');if(s)try{ST=JSON.parse(s)}catch(e){}}
function saveST(){ls('_st',JSON.stringify(ST))}

function sf(id){const el=document.getElementById(id);if(!el)return;ls('f_'+id,el.value||'');saveST()}
function lf(id){const el=document.getElementById(id);if(!el)return;const v=lg('f_'+id);if(v!==null)el.value=v}
function sc(id){const el=document.getElementById(id);if(!el)return;ls('c_'+id,el.checked?'1':'0')}
function lc(id){const el=document.getElementById(id);if(!el)return;const v=lg('c_'+id);if(v!==null)el.checked=v==='1'}
function gv(id){const el=document.getElementById(id);return el?el.value.trim():''}

/* === TABS === */
const TABS=[
  {id:0,label:'M0 Diagnóstico',ico:'🧭'},
  {id:1,label:'M1 Tema',ico:'💡'},
  {id:2,label:'M2 Enfoque',ico:'🔭'},
  {id:3,label:'M3 Alcance',ico:'📏'},
  {id:4,label:'M4 Metodología',ico:'🔬'},
  {id:5,label:'M5 Marco',ico:'📚'},
  {id:6,label:'M6 Hipótesis',ico:'❓'},
  {id:7,label:'M7 Diseño',ico:'🗺'},
  {id:8,label:'M8 Recolección',ico:'📋'},
  {id:9,label:'M9 Análisis',ico:'📈'},
  {id:10,label:'M10 Síntesis',ico:'✅'},
];

function buildTabs(){
  const nav=document.getElementById('tn');nav.innerHTML='';
  TABS.forEach(t=>{
    const b=document.createElement('button');
    b.className='tb'+(t.id===ST.ct?' active':'')+(ST.done.includes(t.id)?' done':'');
    b.textContent=t.ico+' '+t.label;
    b.onclick=()=>goT(t.id);
    nav.appendChild(b);
  });
}

function goT(n){
  document.querySelectorAll('.tp').forEach(p=>p.classList.remove('active'));
  document.getElementById('panel-'+n).classList.add('active');
  ST.ct=n;saveST();buildTabs();updProg();
  if(n===10)buildSyn();
  applyCV();
  window.scrollTo({top:0,behavior:'smooth'});
}

function vanext(n){
  const errs=runVal(n);
  if(!ST.done.includes(n))ST.done.push(n);
  const nxt=nextTab(n);
  const ald=document.getElementById('m'+n+'al');
  if(ald)ald.innerHTML=errs.length?errs.map(e=>mkAl('wn','⚠️','Verifica antes de continuar',e)).join(''):'';
  goT(nxt);
}

function nextTab(n){
  if(n===2){if(ST.enf==='cuanti')return 3;if(ST.enf==='cuali')return 4;if(ST.enf==='mixto')return 3;}
  if(n===3||n===4)return 5;
  return Math.min(n+1,10);
}

function goTPrev(n){
  if(n===5){if(ST.enf==='cuanti'||ST.enf==='mixto')return goT(3);if(ST.enf==='cuali')return goT(4);return goT(2);}
  if(n===6){if(ST.enf==='cuanti'||ST.enf==='mixto')return goT(3);if(ST.enf==='cuali')return goT(4);}
  goT(n-1);
}

function updProg(){
  const done=ST.done.length;const total=10;
  const pct=Math.round((done/total)*100);
  document.getElementById('pf').style.width=pct+'%';
  document.getElementById('pp').textContent=pct+'%';
  document.getElementById('pl').textContent=done===total?'¡Proyecto completado! 🎉':'Módulo '+(ST.ct+1)+' de 11';
}

/* === CONDITIONAL VISIBILITY === */
function applyCV(){
  const e=ST.enf;if(!e)return;
  const cq=e==='cuanti'||e==='mixto',qq=e==='cuali'||e==='mixto';
  const show=(id,v)=>{const el=document.getElementById(id);if(el)el.style.display=v?'block':'none'};
  show('m5qg',cq);show('m5cg',qq);
  const m6t=document.getElementById('m6t');const m6i=document.getElementById('m6i');
  if(m6t)m6t.textContent=e==='cuali'?'Preguntas orientadoras y categorías':'Hipótesis y variables';
  if(m6i)m6i.textContent=e==='cuali'?'En el enfoque cualitativo no se parten de hipótesis cerradas. Se trabaja con preguntas orientadoras y categorías apriorísticas.':'Define operacionalmente tus variables y formula las hipótesis que orientarán el análisis estadístico.';
  show('m6c',cq);show('m6q',e==='cuali');
  show('m7c',cq);show('m7q',qq);
  show('m8mc',cq);show('m8tc',cq);show('m8tq',qq);show('m8rc',cq);show('m8rq',qq);
  show('m9c',cq);show('m9q',qq);
}

/* === ACCORDION === */
function toggleAcc(head){
  head.classList.toggle('open');
  const body=head.nextElementSibling;
  if(body)body.classList.toggle('open');
}

/* === ALERTS === */
function mkAl(type,ico,title,text){
  return`<div class="al ${type}"><div class="ali">${ico}</div><div class="alc"><strong>${title}</strong>${text}</div></div>`;
}

/* === OPT ITEMS === */
function setupOpts(){
  document.querySelectorAll('.oi').forEach(item=>{
    const inp=item.querySelector('input');
    if(!inp)return;
    inp.addEventListener('change',()=>{
      if(inp.type==='radio'){
        document.querySelectorAll(`input[name="${inp.name}"]`).forEach(i=>i.closest('.oi').classList.remove('sel'));
      }
      if(inp.checked)item.classList.add('sel');else item.classList.remove('sel');
    });
    if(inp.checked)item.classList.add('sel');
  });
}

function uc(el,ccId){
  const d=document.getElementById(ccId);
  if(d)d.textContent=(el.value||'').length+' caracteres';
}

/* === M0 DIAGNÓSTICO === */
const DQS={
  tema:[
    {q:'¿Puedes nombrar el fenómeno específico que quieres estudiar (no solo el área)?',opts:['Sí, ya lo identifiqué','Solo tengo el área general']},
    {q:'¿Tienes en mente una población específica?',opts:['Sí','No todavía']},
  ],
  pregunta:[
    {q:'¿Tu pregunta usa verbos como "cómo", "cuál", "en qué medida"?',opts:['Sí','No está bien formulada']},
    {q:'¿Puedes mencionar al menos una variable o fenómeno central?',opts:['Sí','No claramente']},
  ],
  enfoque:[
    {q:'¿Sabes si tu estudio producirá datos numéricos o narrativos?',opts:['Numéricos (cuantitativo)','Narrativos (cualitativo)','Ambos (mixto)']},
    {q:'¿Ya tienes una pregunta de investigación formulada?',opts:['Sí, bien formulada','En borrador','No aún']},
  ],
  metodologia:[
    {q:'¿Ya definiste las variables o categorías de tu estudio?',opts:['Sí, con definición conceptual','Parcialmente','No']},
    {q:'¿Tienes claro el paradigma desde el que trabajas?',opts:['Sí','Más o menos','No']},
  ],
  diseno:[
    {q:'¿Ya tienes definidos tus instrumentos o técnicas de recolección?',opts:['Sí','En general','No']},
    {q:'¿Sabes qué análisis estadístico o metodológico aplicarás?',opts:['Sí','Aproximadamente','No']},
  ],
};

/* moved into init() below */

function showDV(pto){
  ST.pto=pto;
  const wrap=document.getElementById('dv');const qsDiv=document.getElementById('dqs');
  wrap.style.display='block';
  const qs=DQS[pto]||[];
  qsDiv.innerHTML=qs.map((q,i)=>`<div class="dq"><div class="dqt">${q.q}</div><div class="mo2">${q.opts.map((o,j)=>`<button class="mopt" onclick="selDQ(${i},${j},this)">${o}</button>`).join('')}</div></div>`).join('');
}

function selDQ(qi,oi,btn){
  btn.closest('.dq').querySelectorAll('.mopt').forEach(b=>b.classList.remove('sel'));
  btn.classList.add('sel');
  ls('dq_'+qi,oi);
}

function processDiag(){
  const pto=ST.pto;
  if(!pto){document.getElementById('da').innerHTML=mkAl('er','❌','Selecciona un punto de partida','Debes indicar desde dónde inicias.');return;}
  const dest={tema:1,pregunta:1,enfoque:2,metodologia:6,diseno:8};
  if(!ST.done.includes(0))ST.done.push(0);
  goT(dest[pto]||1);
}

/* === M1 EVALUAR PREGUNTA === */
function evalPreg(){
  const preg=gv('m1-preg');const res=document.getElementById('m1er');
  if(!preg){res.innerHTML=mkAl('wn','⚠️','Escribe tu pregunta primero','El campo está vacío.');return;}
  const issues=[],ok=[];
  if(preg.length<20)issues.push('La pregunta parece muy corta. Las preguntas de investigación suelen tener entre 20-80 palabras.');
  else ok.push('Longitud adecuada.');
  if(!preg.includes('?'))issues.push('La pregunta debe terminar con signo de interrogación (?).');
  else ok.push('Tiene forma interrogativa.');
  const vi=['¿cuál','¿cómo','¿qué','¿en qué','¿de qué','¿cuáles','¿cuánto','¿cuánta'];
  if(!vi.some(v=>preg.toLowerCase().startsWith(v)))issues.push('Las preguntas de investigación suelen comenzar con "¿Cuál es...", "¿Cómo...", "¿Qué relación...", "¿En qué medida..."');
  else ok.push('Inicia con verbo interrogativo adecuado.');
  if(['determinar si','comprobar si','demostrar que'].some(v=>preg.toLowerCase().includes(v)))issues.push('"Determinar si" o "comprobar si" son objetivos, no preguntas. Reformula como pregunta directa.');
  let html='';
  if(ok.length)html+=mkAl('ok','✅','Aspectos positivos',ok.map(o=>'• '+o).join('<br>'));
  if(issues.length)html+=mkAl('wn','⚠️','Aspectos a mejorar',issues.map(i=>'• '+i).join('<br>'));
  if(!html)html=mkAl('info','ℹ️','Evaluación preliminar','La pregunta parece estructuralmente adecuada. Continúa al siguiente módulo.');
  res.innerHTML=html;
}

/* === M2 ENFOQUE + PARADIGMA === */
function selEnf(tipo,card){
  ST.enf=tipo;ls('enf',tipo);
  document.querySelectorAll('.ec').forEach(c=>c.classList.remove('sel'));
  card.classList.add('sel');
  const msgs={
    cuanti:`<div class="al info"><div class="ali">📊</div><div class="alc"><strong>Enfoque cuantitativo</strong>Implica: formular hipótesis verificables, definir variables operacionalmente, usar instrumentos estandarizados y analizar datos con estadística descriptiva e inferencial.</div></div>`,
    cuali:`<div class="al info"><div class="ali">💬</div><div class="alc"><strong>Enfoque cualitativo</strong>Implica: trabajar con preguntas orientadoras en lugar de hipótesis cerradas, buscar comprensión profunda más que generalización, y privilegiar la riqueza contextual.</div></div>`,
    mixto:`<div class="al info"><div class="ali">🔀</div><div class="alc"><strong>Enfoque mixto</strong>Combina ambos enfoques. Implica mayor complejidad en el diseño. Debes tener claridad sobre cómo se integrarán ambos componentes y cuál tiene prioridad.</div></div>`,
  };
  const g=document.getElementById('eguia');g.innerHTML=msgs[tipo]||'';g.style.display='block';
  applyCV();checkIncons();
}

function selPar(tipo,card){
  ST.par=tipo;ls('par',tipo);
  document.querySelectorAll('.pc').forEach(c=>c.classList.remove('sel'));
  card.classList.add('sel');
  checkIncons();
}

function checkIncons(){
  const e=ST.enf,p=ST.par;
  const al=document.getElementById('m2al');if(!al)return;
  const issues=[];
  if(e==='cuanti'&&p==='interpretativo')issues.push('El paradigma interpretativo/constructivista privilegia la comprensión subjetiva, más consistente con lo cualitativo. En un estudio cuantitativo, ¿cómo justificas esta combinación?');
  if(e==='cuali'&&p==='pospositivista')issues.push('El paradigma positivista es la base del enfoque cuantitativo. Si tu estudio es cualitativo, considera el paradigma interpretativo o crítico.');
  if(e==='cuanti'&&p==='critico')issues.push('El paradigma crítico es compatible con enfoques cualitativos y mixtos. ¿Tiene tu estudio un componente transformador o emancipador?');
  al.innerHTML=issues.length?issues.map(i=>mkAl('wn','⚠️','Tensión paradigmática detectada',i)).join(''):
    (e&&p?mkAl('ok','✅','Combinación coherente','La combinación de enfoque y paradigma seleccionada es metodológicamente coherente.'):'');
}

/* === M3 ALCANCE === */
function selAlc(tipo){
  ST.alc=tipo;ls('alc',tipo);
  const impls={
    exploratorio:`<div class="al info"><div class="ali">🔭</div><div class="alc"><strong>Implicaciones del alcance exploratorio</strong>No requiere hipótesis formales. Diseño más flexible. Análisis descriptivo. Muestra puede ser pequeña e intencional. Aporta preguntas para estudios posteriores.</div></div>`,
    descriptivo:`<div class="al info"><div class="ali">📋</div><div class="alc"><strong>Implicaciones del alcance descriptivo</strong>Puede tener hipótesis descriptivas. Análisis principalmente descriptivo. Requiere muestra representativa para generalizar. Mide una o más variables sin establecer relaciones causales.</div></div>`,
    correlacional:`<div class="al info"><div class="ali">🔗</div><div class="alc"><strong>Implicaciones del alcance correlacional</strong>Requiere hipótesis correlacionales (H₁ y H₀). Mide dos o más variables y analiza su relación. No establece causalidad. Usa correlaciones de Pearson, Spearman, regresión, etc.</div></div>`,
    explicativo:`<div class="al info"><div class="ali">⚙️</div><div class="alc"><strong>Implicaciones del alcance explicativo</strong>Requiere hipótesis causales. Diseños más complejos (experimental, longitudinal). Análisis de regresión, ANOVA, modelos estructurales. Alta exigencia en el control de variables extrañas.</div></div>`,
  };
  const d=document.getElementById('alci');d.style.display='block';d.innerHTML=impls[tipo]||'';
  if(tipo==='explicativo'&&ST.enf==='cuali'){
    const al=document.getElementById('m3al');if(al)al.innerHTML=mkAl('wn','⚠️','Tensión metodológica','Los estudios cualitativos raramente usan el alcance "explicativo" en el sentido de Sampieri. ¿Buscas comprensión profunda (cualitativo) o prueba de causalidad (cuantitativo)?');
  }
}

/* === M4 METODOLOGÍA CUALITATIVA === */
const MCD={
