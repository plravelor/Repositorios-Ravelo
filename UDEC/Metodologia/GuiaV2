<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guía de Investigación · Psicología</title>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&family=DM+Serif+Display:ital@0;1&display=swap" rel="stylesheet">
<style>
:root{
  --bg:#F8F6F1;--srf:#FFFFFF;--srf2:#F2F0EB;
  --brd:#E2DDD6;--brd2:#CEC9C0;
  --p:#2E6F75;--pl:#E8F4F5;--pd:#1F5057;
  --ac:#C67C00;--acl:#FFF3D9;
  --ok:#2D7A4F;--okl:#E8F5ED;
  --er:#B83B3B;--erl:#FDF0EF;
  --wn:#7A5000;--wnl:#FFF8E1;
  --tx:#1C1C2E;--tx2:#4B4B6B;--tx3:#7A7A9A;--mu:#9090A8;
  --sh:0 1px 4px rgba(0,0,0,.07),0 4px 16px rgba(0,0,0,.05);
  --sh2:0 1px 3px rgba(0,0,0,.08);
  --r:10px;--rs:6px;
  --f:"DM Sans",system-ui,sans-serif;
  --fs:"DM Serif Display",Georgia,serif;
}
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--f);background:var(--bg);color:var(--tx);font-size:15px;line-height:1.65;min-height:100vh}
::-webkit-scrollbar{width:5px}::-webkit-scrollbar-track{background:var(--srf2)}::-webkit-scrollbar-thumb{background:var(--brd2);border-radius:3px}
#ah{background:var(--srf);border-bottom:1px solid var(--brd);position:sticky;top:0;z-index:100;box-shadow:var(--sh2)}
.hi{max-width:960px;margin:0 auto;padding:12px 20px 0}
.ht{display:flex;align-items:center;justify-content:space-between;gap:12px;margin-bottom:8px}
.at{font-family:var(--fs);font-size:19px;color:var(--pd)}
.at span{font-family:var(--f);font-size:12px;font-weight:500;color:var(--tx3);display:block;margin-top:-2px}
.ha{display:flex;gap:8px;align-items:center}
.pbl{font-size:11.5px;color:var(--tx3);font-weight:500;letter-spacing:.04em;text-transform:uppercase;display:flex;justify-content:space-between;margin-bottom:5px}
.pbar{height:4px;background:var(--brd);border-radius:2px;overflow:hidden}
.pf{height:100%;background:linear-gradient(90deg,var(--p) 0%,#4AA8AF 100%);border-radius:2px;transition:width .4s ease}
.tn{display:flex;gap:2px;overflow-x:auto;scrollbar-width:none;-ms-overflow-style:none;padding-bottom:1px}
.tn::-webkit-scrollbar{display:none}
.tb{flex-shrink:0;padding:7px 14px;border:none;background:transparent;font-family:var(--f);font-size:12.5px;font-weight:500;color:var(--tx3);cursor:pointer;border-bottom:2px solid transparent;transition:all .18s;white-space:nowrap;border-radius:4px 4px 0 0}
.tb:hover{color:var(--p);background:var(--pl)}.tb.active{color:var(--p);border-bottom-color:var(--p);font-weight:600}
.tb.done::after{content:"\2713";font-size:10px;color:var(--ok);margin-left:3px}
.mw{max-width:960px;margin:0 auto;padding:28px 20px 80px}
.tp{display:none}.tp.active{display:block}
.ml{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--p);margin-bottom:5px}
.mt{font-family:var(--fs);font-size:26px;color:var(--tx);line-height:1.2;margin-bottom:8px}
.mi{font-size:14.5px;color:var(--tx2);max-width:680px;line-height:1.7;margin-bottom:20px}
.card{background:var(--srf);border:1px solid var(--brd);border-radius:var(--r);box-shadow:var(--sh);padding:20px 22px;margin-bottom:16px}
.ct{font-weight:600;font-size:14.5px;color:var(--tx);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.tg{font-size:10px;font-weight:700;letter-spacing:.07em;text-transform:uppercase;padding:2px 7px;border-radius:20px}
.to{background:var(--srf2);color:var(--tx3)}.tr{background:var(--pl);color:var(--p)}
.fg{margin-bottom:16px}
.fl{display:block;font-size:13px;font-weight:600;color:var(--tx2);margin-bottom:6px}
.fh{font-size:12px;color:var(--tx3);margin-bottom:6px;font-style:italic}
textarea,input[type=text],select{width:100%;border:1.5px solid var(--brd);border-radius:var(--rs);padding:10px 13px;font-family:var(--f);font-size:14px;color:var(--tx);background:var(--srf);transition:border-color .18s,box-shadow .18s;resize:vertical}
textarea:focus,input[type=text]:focus,select:focus{outline:none;border-color:var(--p);box-shadow:0 0 0 3px rgba(46,111,117,.1)}
textarea{min-height:80px}select{cursor:pointer}
.cc{font-size:11.5px;color:var(--mu);text-align:right;margin-top:4px}
.og{display:flex;flex-direction:column;gap:8px}
.oi{display:flex;align-items:flex-start;gap:11px;padding:10px 13px;border:1.5px solid var(--brd);border-radius:var(--rs);cursor:pointer;transition:all .15s;background:var(--srf)}
.oi:hover,.oi.sel{border-color:var(--p);background:var(--pl)}
.oi input{width:auto;margin-top:2px;flex-shrink:0;accent-color:var(--p)}
.ot{flex:1}.otn{font-weight:600;font-size:14px;color:var(--tx)}.otd{font-size:12.5px;color:var(--tx3);margin-top:2px}
.ah{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;cursor:pointer;background:var(--srf);font-weight:600;font-size:13.5px;color:var(--tx);user-select:none;transition:background .15s;border:none;width:100%;text-align:left;border:1px solid var(--brd);border-radius:var(--rs);margin-bottom:8px}
.ah:hover{background:var(--srf2)}.ai{transition:transform .25s;font-style:normal}.ah.open .ai{transform:rotate(180deg)}
.ab{display:none;padding:14px 16px;background:var(--srf2);border:1px solid var(--brd);border-top:none;border-radius:0 0 var(--rs) var(--rs);font-size:13.5px;color:var(--tx2);line-height:1.7;margin-top:-8px;margin-bottom:8px}.ab.open{display:block}
.al{border-radius:var(--rs);padding:12px 15px;font-size:13.5px;display:flex;gap:10px;align-items:flex-start;margin-bottom:14px;line-height:1.6}
.ali{font-size:17px;flex-shrink:0;margin-top:1px}.alc{flex:1}.alc strong{font-weight:700;display:block;margin-bottom:3px}
.al.wn{background:var(--wnl);border:1.5px solid #DDB84A}.al.wn .alc strong{color:var(--wn)}
.al.er{background:var(--erl);border:1.5px solid #E88585}.al.er .alc strong{color:var(--er)}
.al.ok{background:var(--okl);border:1.5px solid #6BBF8A}.al.ok .alc strong{color:var(--ok)}
.al.info{background:var(--pl);border:1.5px solid #85C2C8}.al.info .alc strong{color:var(--p)}
.btn{display:inline-flex;align-items:center;gap:7px;padding:9px 18px;border-radius:var(--rs);font-family:var(--f);font-size:13.5px;font-weight:600;cursor:pointer;border:none;transition:all .18s}
.bp{background:var(--p);color:white}.bp:hover{background:var(--pd)}
.bs{background:var(--srf);color:var(--tx);border:1.5px solid var(--brd2)}.bs:hover{border-color:var(--p);color:var(--p)}
.bg{background:transparent;color:var(--p)}.bg:hover{background:var(--pl)}
.bsm{padding:6px 13px;font-size:12.5px}.blg{padding:12px 24px;font-size:15px}
.br{display:flex;gap:10px;flex-wrap:wrap;margin-top:18px;align-items:center}.brr{justify-content:flex-end}
.pb-box{background:#F5F3FF;border:1.5px solid #C0B8E8;border-radius:var(--rs);margin-top:14px;overflow:hidden}
.pb-h{background:#6B5CDB;color:white;padding:10px 15px;font-size:12.5px;font-weight:700;display:flex;align-items:center;justify-content:space-between;gap:10px}
.pb-b{padding:13px 15px;font-family:"Courier New",monospace;font-size:12.5px;color:#2D2460;line-height:1.65;white-space:pre-wrap;word-break:break-word;max-height:300px;overflow-y:auto}
.ss{background:var(--srf);border:1px solid var(--brd);border-radius:var(--r);padding:18px 20px;margin-bottom:14px}
.sl{font-size:10.5px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;color:var(--p);margin-bottom:6px}
.sc{font-size:14.5px;color:var(--tx);line-height:1.7}.se{font-style:italic;color:var(--mu)}
.g2{display:grid;grid-template-columns:1fr 1fr;gap:14px}
.g3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:12px}
@media(max-width:640px){.g2,.g3{grid-template-columns:1fr}}
.eg{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin-bottom:18px}
@media(max-width:560px){.eg{grid-template-columns:1fr}}
.ec{border:2px solid var(--brd);border-radius:var(--r);padding:16px 14px;text-align:center;cursor:pointer;transition:all .18s;background:var(--srf)}
.ec:hover,.ec.sel{border-color:var(--p);background:var(--pl)}
.ec .ico{font-size:28px;margin-bottom:8px}.ec h4{font-size:15px;font-weight:700;color:var(--tx);margin-bottom:5px}
.ec p{font-size:12px;color:var(--tx3);line-height:1.5}
.pc{border:2px solid var(--brd);border-radius:var(--r);padding:16px;cursor:pointer;transition:all .18s;background:var(--srf)}
.pc:hover,.pc.sel{border-color:var(--p)}.pc.sel{background:var(--pl)}
.pc h4{font-family:var(--fs);font-size:16px;color:var(--tx);margin-bottom:6px}
.pc p{font-size:12.5px;color:var(--tx3);line-height:1.6}
.pc .pt{display:flex;gap:5px;flex-wrap:wrap;margin-top:10px}
.ptg{font-size:10.5px;font-weight:600;padding:2px 8px;border-radius:20px;background:var(--srf2);color:var(--tx3)}
.mc{border:2px solid var(--brd);border-radius:var(--r);padding:15px;cursor:pointer;transition:all .18s;background:var(--srf)}
.mc:hover,.mc.sel{border-color:#7B5CDB;background:#F5F3FF}
.mc h5{font-weight:700;font-size:14px;margin-bottom:5px}
.mc p{font-size:12.5px;color:var(--tx3);line-height:1.5}
.mc .mu{font-size:11.5px;margin-top:8px;color:#5040B0;font-weight:600}
.ht-box{background:var(--acl);border:1.5px solid #DDB84A;border-radius:var(--rs);padding:13px 16px;font-size:14px;color:var(--wn);font-style:italic;margin-bottom:12px;line-height:1.7}
.flow{display:flex;align-items:center;gap:8px;flex-wrap:wrap;margin:14px 0}
.fb{background:var(--pl);border:1.5px solid var(--p);border-radius:var(--rs);padding:8px 13px;font-size:13px;font-weight:600;color:var(--p)}
.fa{color:var(--brd2);font-size:18px}
.mo{position:fixed;inset:0;background:rgba(0,0,0,.45);z-index:200;display:none;align-items:center;justify-content:center;padding:20px}
.mo.open{display:flex}
.mb{background:var(--srf);border-radius:var(--r);box-shadow:0 8px 40px rgba(0,0,0,.25);width:100%;max-width:640px;max-height:88vh;overflow-y:auto;padding:26px}
.mh{display:flex;align-items:center;justify-content:space-between;margin-bottom:18px}
.mtl{font-family:var(--fs);font-size:20px;color:var(--tx)}
.cb{background:var(--srf2);border:none;width:30px;height:30px;border-radius:50%;cursor:pointer;font-size:16px;color:var(--tx3);display:flex;align-items:center;justify-content:center}
.cb:hover{background:var(--brd)}
.et{background:var(--srf2);border:1px solid var(--brd);border-radius:var(--rs);padding:16px;font-size:13px;line-height:1.75;white-space:pre-wrap;word-break:break-word;color:var(--tx2);max-height:400px;overflow-y:auto;font-family:"Courier New",monospace}
.badge{display:inline-block;padding:2px 9px;border-radius:20px;font-size:11px;font-weight:700}
.bq{background:#E3F2FD;color:#1565C0}.bql{background:#EDE7F6;color:#4527A0}.bm{background:#E8F5E9;color:#2E7D32}
.dq{background:var(--srf);border:1.5px solid var(--brd);border-radius:var(--rs);padding:14px 16px;margin-bottom:12px}
.dqt{font-size:14px;font-weight:600;color:var(--tx);margin-bottom:10px}
.mo2{display:flex;gap:8px;flex-wrap:wrap}
.mopt{padding:6px 14px;border-radius:20px;border:1.5px solid var(--brd);background:var(--srf);font-size:13px;font-weight:500;cursor:pointer;transition:all .15s;color:var(--tx2)}
.mopt:hover,.mopt.sel{border-color:var(--p);color:var(--p);background:var(--pl);font-weight:600}
ul.sty{padding-left:18px}ul.sty li{margin-bottom:5px;font-size:13.5px;color:var(--tx2)}
.sm{font-size:12.5px;color:var(--tx3)}hr{border:none;border-top:1px solid var(--brd);margin:16px 0}
@media print{#ah,.br,.btn,.pb-box{display:none!important}.tp{display:block!important}.card{box-shadow:none;border:1px solid #ddd}body{background:white;font-size:12pt}}
</style>
</head>
<body>

<!-- HEADER -->
<div id="ah">
<div class="hi">
  <div class="ht">
    <div><div class="at">Guía de Investigación<span>Psicología · Metodología de la Investigación · Sampieri &amp; Bautista</span></div></div>
    <div class="ha">
      <button class="btn bs bsm" onclick="openExp()">&#8595; Exportar</button>
      <button class="btn bg bsm" onclick="resetAll()" title="Reiniciar todo">&#8635;</button>
    </div>
  </div>
  <div style="margin-bottom:8px">
    <div class="pbl"><span id="pl">Progreso del proyecto</span><span id="pp">0%</span></div>
    <div class="pbar"><div class="pf" id="pf" style="width:0%"></div></div>
  </div>
  <nav class="tn" id="tn"></nav>
</div>
</div>

<div class="mw">

<!-- M0 -->
<div class="tp active" id="panel-0">
<div class="ml">Módulo 0</div><h1 class="mt">&#10004; ¿Desde dónde empiezas?</h1>
<p class="mi">Esta herramienta te acompaña desde una idea inicial hasta un proyecto de investigación formalizado, coherente y exportable. Identifica tu punto de partida para que el recorrido sea eficiente.</p>
<div id="sr" class="al info" style="display:none"><div class="ali">&#128190;</div><div class="alc"><strong>Sesión anterior encontrada</strong><div style="margin-top:8px;display:flex;gap:8px"><button class="btn bp bsm" onclick="restoreSession()">Continuar donde lo dejé</button><button class="btn bs bsm" onclick="resetAll()">Empezar de nuevo</button></div></div></div>
<div class="card"><div class="ct">¿En qué punto estás?</div>
<div class="og" id="dp">
<label class="oi"><input type="radio" name="pto" value="tema"><div class="ot"><div class="otn">Solo tengo un tema o área de interés</div><div class="otd">Tengo una idea general pero no sé cómo convertirla en investigación.</div></div></label>
<label class="oi"><input type="radio" name="pto" value="pregunta"><div class="ot"><div class="otn">Tengo una pregunta pero no sé cómo desarrollarla</div><div class="otd">Puedo enunciar lo que quiero saber, pero no sé qué enfoque ni metodología usar.</div></div></label>
<label class="oi"><input type="radio" name="pto" value="enfoque"><div class="ot"><div class="otn">Sé mi enfoque pero no la metodología específica</div><div class="otd">Sé que es cuantitativo, cualitativo o mixto, pero no qué diseño o análisis aplicar.</div></div></label>
<label class="oi"><input type="radio" name="pto" value="metodologia"><div class="ot"><div class="otn">Tengo tema, pregunta y enfoque — necesito hipótesis, variables o categorías</div><div class="otd">El planteamiento está definido pero falta la operacionalización.</div></div></label>
<label class="oi"><input type="radio" name="pto" value="diseno"><div class="ot"><div class="otn">Tengo todo lo anterior — necesito diseñar la recolección y el análisis</div><div class="otd">El proyecto está planteado; falta la parte operativa.</div></div></label>
</div></div>
<div id="dv" style="display:none"><div class="card"><div class="ct">Verificación rápida</div><div id="dqs"></div></div></div>
<div id="da"></div>
<div class="br"><button class="btn bp blg" onclick="processDiag()">Verificar y continuar &#8594;</button></div>
</div>

<!-- M1 -->
<div class="tp" id="panel-1">
<div class="ml">Módulo 1</div><h1 class="mt">Del tema a la pregunta de investigación</h1>
<p class="mi">El punto de partida de toda investigación es una pregunta bien formulada. Aquí la construirás paso a paso asegurando que sea clara, viable, pertinente e investigable.</p>
<button class="ah" onclick="toggleAcc(this)">&#9660; ¿Cuál es la diferencia entre tema, problema y pregunta? <i class="ai">&#9660;</i></button>
<div class="ab"><p><strong>Tema:</strong> área amplia. Ej: "ansiedad en adolescentes".</p><p style="margin-top:8px"><strong>Problema:</strong> situación específica que merece estudio. Ej: "adolescentes de Facatativá que trabajan y estudian reportan ansiedad alta pero no acceden a atención psicológica".</p><p style="margin-top:8px"><strong>Pregunta de investigación:</strong> versión interrogativa y delimitada del problema. Ej: "¿Cuál es la relación entre la carga laboral y los síntomas de ansiedad en adolescentes estudiantes-trabajadores de Facatativá en 2026?"</p></div>
<div class="card" style="margin-top:14px">
<div class="ct">1. Describe tu tema <span class="tg tr">Obligatorio</span></div>
<div class="fg"><label class="fl">¿De qué trata tu investigación?</label><textarea id="m1-tema" rows="2" placeholder="Ej: ansiedad en estudiantes universitarios, violencia de pareja, estrategias de afrontamiento..." oninput="sf('m1-tema');uc(this,'cc1')"></textarea><div class="cc" id="cc1">0 caracteres</div></div>
</div>
<div class="card"><div class="ct">2. Delimita el tema</div>
<div class="g2">
<div class="fg"><label class="fl">Población</label><div class="fh">¿A quiénes estudiarás? Sé específico/a.</div><input type="text" id="m1-pop" placeholder="Ej: estudiantes universitarios 18-25 años, UDEC Facatativá" oninput="sf('m1-pop')"></div>
<div class="fg"><label class="fl">Contexto</label><div class="fh">¿Dónde y cuándo?</div><input type="text" id="m1-ctx" placeholder="Ej: UDEC Facatativá, semestre 2026-I" oninput="sf('m1-ctx')"></div>
</div>
<div class="fg"><label class="fl">Fenómeno específico</label><div class="fh">¿Qué aspecto del tema estudiarás?</div><input type="text" id="m1-fen" placeholder="Ej: relación entre carga académica y síntomas de ansiedad" oninput="sf('m1-fen')"></div>
</div>
<div class="card"><div class="ct">3. Formula tu pregunta de investigación</div>
<div class="fg"><label class="fl">Pregunta de investigación</label><div class="fh">Inicia con ¿Cuál...?, ¿Cómo...?, ¿Qué...?, ¿En qué medida...? Debe ser específica y delimitable.</div><textarea id="m1-preg" rows="3" placeholder="¿Cuál es la relación entre...? / ¿Cómo viven los/las...? / ¿Qué factores..." oninput="sf('m1-preg');uc(this,'cc2')"></textarea><div class="cc" id="cc2">0 caracteres</div></div>
<button class="btn bg bsm" onclick="evalPreg()">&#128269; Evaluar esta pregunta</button>
<div id="m1er" style="margin-top:12px"></div>
</div>
<div class="card"><div class="ct">4. Objetivos del estudio</div>
<div class="fg"><label class="fl">Objetivo general</label><div class="fh">Verbo cognitivo + qué + en quién + dónde. Verbos: analizar, describir, comprender, determinar, explorar, comparar.</div><textarea id="m1-og" rows="2" placeholder="Ej: Analizar la relación entre la carga académica y los síntomas de ansiedad en estudiantes universitarios de la UDEC Facatativá durante el semestre 2026-I." oninput="sf('m1-og')"></textarea></div>
<div class="fg"><label class="fl">Objetivos específicos (uno por línea)</label><textarea id="m1-oe" rows="4" placeholder="- Identificar el nivel de síntomas de ansiedad en la población...&#10;- Describir las características de la carga académica...&#10;- Establecer la relación entre ambas variables..." oninput="sf('m1-oe')"></textarea></div>
</div>
<div class="card"><div class="ct">&#129302; Solicitar evaluación de IA</div><p class="sm" style="margin-bottom:12px">Genera un prompt para revisar tu pregunta y objetivos con Claude o ChatGPT:</p><button class="btn bg bsm" onclick="genPM1()">Generar prompt de evaluación</button><div id="pm1" style="display:none;margin-top:12px"></div></div>
<div id="m1al"></div>
<div class="br brr"><button class="btn bs" onclick="goT(0)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(1)">Siguiente &#8594; Enfoque y paradigma</button></div>
</div>

<!-- M2 -->
<div class="tp" id="panel-2">
<div class="ml">Módulo 2</div><h1 class="mt">Enfoque y paradigma de investigación</h1>
<p class="mi">El enfoque determina cómo producirás conocimiento. Esta decisión debe ser coherente con la naturaleza del fenómeno y con tu pregunta de investigación.</p>
<div class="card"><div class="ct">¿Qué enfoque tiene tu investigación?</div>
<div class="eg" id="esel">
<div class="ec" onclick="selEnf('cuanti',this)"><div class="ico">&#128202;</div><h4>Cuantitativo</h4><p>Mide variables, busca relaciones numéricas, generaliza resultados con estadística.</p></div>
<div class="ec" onclick="selEnf('cuali',this)"><div class="ico">&#128172;</div><h4>Cualitativo</h4><p>Comprende experiencias, significados y procesos desde la perspectiva de los participantes.</p></div>
<div class="ec" onclick="selEnf('mixto',this)"><div class="ico">&#128256;</div><h4>Mixto</h4><p>Combina ambos enfoques en un mismo estudio. Puede ser complementario o secuencial.</p></div>
</div>
<div id="eguia" style="display:none"></div>
</div>
<button class="ah" onclick="toggleAcc(this)">&#9660; ¿Cómo decido qué enfoque corresponde? <i class="ai">&#9660;</i></button>
<div class="ab"><div class="g2"><div><strong style="color:#1565C0">Indicios cuantitativos:</strong><ul class="sty" style="margin-top:8px"><li>Tu pregunta usa "cuánto", "qué relación", "en qué medida"</li><li>Quieres medir con instrumento estandarizado</li><li>Buscas generalizar a una población</li></ul></div><div><strong style="color:#4527A0">Indicios cualitativos:</strong><ul class="sty" style="margin-top:8px"><li>Tu pregunta usa "cómo viven", "qué significado tiene"</li><li>Te interesa la experiencia subjetiva</li><li>Necesitas profundidad más que amplitud</li></ul></div></div></div>
<div class="card" style="margin-top:14px"><div class="ct">Paradigma de investigación</div>
<p class="sm" style="margin-bottom:14px">El paradigma es el conjunto de supuestos sobre la realidad y sobre cómo conocerla. Elige el que mejor corresponde a tu enfoque y fenómeno:</p>
<div class="g2" id="psel">
<div class="pc" onclick="selPar('pospositivista',this)"><h4>Positivista / Postpositivista</h4><p>La realidad existe independientemente del observador. El conocimiento se produce midiendo y verificando hipótesis.</p><div class="pt"><span class="ptg">Medición</span><span class="ptg">Hipótesis</span><span class="ptg">Generalización</span></div></div>
<div class="pc" onclick="selPar('interpretativo',this)"><h4>Interpretativo / Constructivista</h4><p>La realidad social es construida por los actores. El conocimiento emerge de la comprensión de significados en contexto.</p><div class="pt"><span class="ptg">Significados</span><span class="ptg">Contexto</span><span class="ptg">Comprensión</span></div></div>
<div class="pc" onclick="selPar('critico',this)"><h4>Crítico / Emancipador</h4><p>El conocimiento tiene una dimensión política y transformadora. El investigador toma posición ante las relaciones de poder.</p><div class="pt"><span class="ptg">Transformación</span><span class="ptg">Participación</span><span class="ptg">Reflexividad</span></div></div>
<div class="pc" onclick="selPar('pragmatico',this)"><h4>Pragmático</h4><p>La verdad se evalúa por sus consecuencias prácticas. El método se elige por lo que funciona mejor para responder la pregunta.</p><div class="pt"><span class="ptg">Utilidad</span><span class="ptg">Pluralismo</span><span class="ptg">Mixto</span></div></div>
</div></div>
<div class="card"><div class="ct">Justifica tu elección</div><div class="fg"><label class="fl">¿Por qué este enfoque y paradigma son coherentes con tu pregunta?</label><textarea id="m2-jus" rows="3" placeholder="Ej: El fenómeno de la experiencia de duelo no puede reducirse a números sin perder su riqueza. El enfoque cualitativo permite capturar los significados que los participantes construyen..." oninput="sf('m2-jus')"></textarea></div></div>
<div id="m2al"></div>
<div class="br brr"><button class="btn bs" onclick="goT(1)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(2)">Siguiente &#8594;</button></div>
</div>

<!-- M3 ALCANCE -->
<div class="tp" id="panel-3">
<div class="ml">Módulo 3 · <span class="badge bq">Cuantitativo</span> <span class="badge bm">Mixto</span></div>
<h1 class="mt">Alcance de la investigación</h1>
<p class="mi">El alcance define qué tipo de conocimiento producirá tu investigación y determina el tipo de hipótesis, diseño y análisis que necesitas.</p>
<button class="ah" onclick="toggleAcc(this)">&#9660; ¿Por qué importa el alcance? <i class="ai">&#9660;</i></button>
<div class="ab"><p>El alcance responde: <em>¿qué tan profundo y qué tipo de conocimiento quiero generar?</em> Depende del estado del conocimiento sobre el tema y de lo que la pregunta pretende responder.</p><div class="flow" style="margin-top:12px"><div class="fb">Exploratorio</div><div class="fa">→</div><div class="fb">Descriptivo</div><div class="fa">→</div><div class="fb">Correlacional</div><div class="fa">→</div><div class="fb">Explicativo</div></div><p class="sm" style="margin-top:8px">Este es un continuo, no una jerarquía. El alcance adecuado depende de cuánto se sabe ya sobre el fenómeno.</p></div>
<div class="card" style="margin-top:14px"><div class="ct">Elige el alcance de tu estudio</div>
<div class="og">
<label class="oi"><input type="radio" name="alc" value="exploratorio" onclick="selAlc('exploratorio')"><div class="ot"><div class="otn">Exploratorio</div><div class="otd">Para temas poco estudiados. No requiere hipótesis formales. Genera preguntas más que respuestas definitivas.</div></div></label>
<label class="oi"><input type="radio" name="alc" value="descriptivo" onclick="selAlc('descriptivo')"><div class="ot"><div class="otn">Descriptivo</div><div class="otd">Describe características de un fenómeno conocido. No establece relaciones causales. Puede tener hipótesis descriptivas.</div></div></label>
<label class="oi"><input type="radio" name="alc" value="correlacional" onclick="selAlc('correlacional')"><div class="ot"><div class="otn">Correlacional</div><div class="otd">Determina si existe relación entre variables. No establece causalidad. Requiere hipótesis correlacionales.</div></div></label>
<label class="oi"><input type="radio" name="alc" value="explicativo" onclick="selAlc('explicativo')"><div class="ot"><div class="otn">Explicativo</div><div class="otd">Busca determinar por qué ocurre un fenómeno. Establece relaciones de causalidad. Requiere diseños más rigurosos.</div></div></label>
</div><div id="alci" style="display:none;margin-top:14px"></div></div>
<div class="card"><div class="ct">Justifica el alcance</div><div class="fg"><label class="fl">¿Por qué este alcance corresponde a tu pregunta y al estado del conocimiento?</label><textarea id="m3-jus" rows="3" placeholder="Ej: El tema de X en población Y en Colombia ha sido poco estudiado. Los estudios existentes se limitan a describir... Por eso, un alcance correlacional es apropiado porque ya existe base teórica." oninput="sf('m3-jus')"></textarea></div></div>
<div id="m3al"></div>
<div class="br brr"><button class="btn bs" onclick="goT(2)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(3)">Siguiente &#8594;</button></div>
</div>

<!-- M4 METODOLOGÍA CUALITATIVA -->
<div class="tp" id="panel-4">
<div class="ml">Módulo 4 · <span class="badge bql">Cualitativo</span></div>
<h1 class="mt">Metodología cualitativa específica</h1>
<p class="mi">El enfoque cualitativo tiene diversas tradiciones. La elección debe ser coherente con tu fenómeno, objetivo y relación con el campo.</p>
<div class="card"><div class="ct">Elige la metodología que mejor responde a tu fenómeno</div>
<div class="g2" id="mcg">
<div class="mc" onclick="selMC('fenomenologia',this)"><h5>&#127917; Fenomenología</h5><p>Estudia la experiencia vivida tal como la perciben los participantes. Busca la esencia del fenómeno.</p><p class="mu">Úsala cuando te interesa comprender cómo vive alguien un fenómeno.</p></div>
<div class="mc" onclick="selMC('teoria-fundamentada',this)"><h5>&#127807; Teoría Fundamentada</h5><p>Construye teoría a partir de los datos. Proceso inductivo y sistemático con saturación teórica.</p><p class="mu">Úsala cuando quieres generar una explicación teórica de un proceso.</p></div>
<div class="mc" onclick="selMC('etnografia',this)"><h5>&#127757; Etnografía</h5><p>Describe e interpreta prácticas y creencias de un grupo cultural en su contexto natural.</p><p class="mu">Úsala cuando quieres comprender la cultura o prácticas de un grupo.</p></div>
<div class="mc" onclick="selMC('iap',this)"><h5>&#9994; IAP</h5><p>Combina investigación y transformación social. Los participantes co-producen el conocimiento.</p><p class="mu">Úsala cuando el objetivo incluye transformar o empoderar a los participantes.</p></div>
<div class="mc" onclick="selMC('narrativa',this)"><h5>&#128214; Investigación Narrativa</h5><p>Analiza historias de vida y relatos para comprender cómo las personas construyen sentido.</p><p class="mu">Úsala cuando las trayectorias vitales o relatos son el objeto de estudio.</p></div>
<div class="mc" onclick="selMC('estudio-caso',this)"><h5>&#128270; Estudio de Caso</h5><p>Análisis profundo de un caso en su contexto real con múltiples fuentes de evidencia.</p><p class="mu">Úsala cuando quieres entender un caso específico en profundidad.</p></div>
</div><div id="mcd" style="display:none;margin-top:14px"></div></div>
<div class="card"><div class="ct">Justifica tu elección metodológica</div><div class="fg"><label class="fl">¿Por qué esta metodología responde mejor a tu fenómeno?</label><textarea id="m4-jus" rows="3" placeholder="Ej: La fenomenología es adecuada porque mi pregunta indaga sobre la experiencia subjetiva. No busco generar teoría sino comprender la esencia de esa experiencia." oninput="sf('m4-jus')"></textarea></div></div>
<div id="m4al"></div>
<div class="br brr"><button class="btn bs" onclick="goT(2)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(4)">Siguiente &#8594; Marco teórico</button></div>
</div>

<!-- M5 MARCO -->
<div class="tp" id="panel-5">
<div class="ml">Módulo 5</div><h1 class="mt">Marco teórico y revisión de literatura</h1>
<p class="mi">El marco teórico no es un glosario de conceptos. Es el argumento que justifica conceptualmente tu investigación y sitúa tu estudio en el conocimiento existente.</p>
<div id="m5qg" style="display:none"></div><div id="m5cg" style="display:none"></div>
<div class="card"><div class="ct">Conceptos clave</div><div class="fg"><label class="fl">¿Cuáles son los 3-5 conceptos centrales de tu marco?</label><textarea id="m5-con" rows="3" placeholder="Ej: ansiedad (Beck, 1985), afrontamiento (Lazarus y Folkman, 1986), carga académica, regulación emocional..." oninput="sf('m5-con')"></textarea></div></div>
<div class="card"><div class="ct">Autores y perspectivas teóricas</div><div class="fg"><label class="fl">¿Desde qué autores o tradiciones abordarás cada concepto?</label><textarea id="m5-aut" rows="4" placeholder="Concepto 1: Ansiedad — Beck (1985), teoría cognitiva. También se revisará DSM-5 y Spielberger.&#10;Concepto 2: Afrontamiento — Lazarus y Folkman (1986), modelo transaccional." oninput="sf('m5-aut')"></textarea></div></div>
<div class="card"><div class="ct">Relación entre conceptos</div><div class="fg"><label class="fl">¿Cómo se relacionan teóricamente tus conceptos? ¿Qué dice la literatura sobre esa relación?</label><div class="fh">Este es el núcleo del marco: no solo definir, sino articular por qué tendría sentido que X y Y se relacionen.</div><textarea id="m5-rel" rows="4" placeholder="La literatura sugiere que A influye en B a través del mecanismo C (Autor, año). Sin embargo, D puede moderar esa relación cuando... Por eso, el estudio se centra en..." oninput="sf('m5-rel')"></textarea></div></div>
<div class="card"><div class="ct">Estado del arte y vacío de conocimiento</div><div class="fg"><label class="fl">¿Qué se sabe ya sobre el tema? ¿Qué vacío llena tu investigación?</label><textarea id="m5-est" rows="3" placeholder="Los estudios existentes han abordado X en contextos norteamericanos y europeos, pero no en Colombia... Mi investigación busca llenar ese vacío al..." oninput="sf('m5-est')"></textarea></div></div>
<div class="card"><div class="ct">&#129302; Revisar coherencia del marco con IA</div><button class="btn bg bsm" onclick="genPM5()">Generar prompt de revisión</button><div id="pm5" style="display:none;margin-top:12px"></div></div>
<div id="m5al"></div>
<div class="br brr"><button class="btn bs" onclick="goTPrev(5)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(5)">Siguiente &#8594;</button></div>
</div>

<!-- M6 HIP/VARS/CATS -->
<div class="tp" id="panel-6">
<div class="ml">Módulo 6</div><h1 class="mt" id="m6t">Hipótesis y variables</h1>
<p class="mi" id="m6i">Define cómo vas a operacionalizar tu pregunta en términos medibles o interpretables.</p>
<div id="m6c" style="display:none">
<button class="ah" onclick="toggleAcc(this)">&#9660; ¿Cuándo se formulan hipótesis y de qué tipo? <i class="ai">&#9660;</i></button>
<div class="ab"><p><strong>H₁ (investigación):</strong> proposición que predice la relación entre variables. Puede ser descriptiva, correlacional o de diferencia.</p><p style="margin-top:8px"><strong>H₀ (nula):</strong> proposición que niega la relación esperada. Es lo que el análisis estadístico intenta refutar.</p><p style="margin-top:8px"><strong>¿Siempre se necesitan?</strong> No. Exploratorios y descriptivos generalmente no. Correlacionales y explicativos sí.</p></div>
<div class="card" style="margin-top:14px"><div class="ct">Hipótesis de investigación</div>
<div class="fg"><label class="fl">H₁ — Hipótesis general</label><div class="ht-box">"Existe una relación [positiva/negativa/significativa] entre [Variable A] y [Variable B] en [población] durante [período]."</div><textarea id="m6-hip" rows="3" placeholder="Ej: Existe una relación negativa y estadísticamente significativa entre el nivel de estrés académico y el rendimiento académico en estudiantes universitarios de primer semestre de la UDEC." oninput="sf('m6-hip');evalHip()"></textarea></div>
<div id="m6he" style="margin-top:8px"></div>
<div class="fg" style="margin-top:12px"><label class="fl">H₀ — Hipótesis nula</label><textarea id="m6-h0" rows="2" placeholder="Ej: No existe relación estadísticamente significativa entre el nivel de estrés académico y el rendimiento académico en la población estudiada." oninput="sf('m6-h0')"></textarea></div></div>
<div class="card"><div class="ct">Variables</div>
<div class="fg"><label class="fl">Variable independiente (VI)</label><div class="g2"><div><label class="fl" style="font-size:12px;font-weight:500">Nombre conceptual</label><input type="text" id="m6-vic" placeholder="Ej: Estrés académico" oninput="sf('m6-vic')"></div><div><label class="fl" style="font-size:12px;font-weight:500">Operacionalización</label><input type="text" id="m6-vio" placeholder="Ej: Puntaje total en el SISCO-SV-21" oninput="sf('m6-vio')"></div></div></div>
<div class="fg"><label class="fl">Variable dependiente (VD)</label><div class="g2"><div><label class="fl" style="font-size:12px;font-weight:500">Nombre conceptual</label><input type="text" id="m6-vdc" placeholder="Ej: Rendimiento académico" oninput="sf('m6-vdc')"></div><div><label class="fl" style="font-size:12px;font-weight:500">Operacionalización</label><input type="text" id="m6-vdo" placeholder="Ej: Promedio acumulado del semestre" oninput="sf('m6-vdo')"></div></div></div>
<div class="fg"><label class="fl">Variables de control</label><textarea id="m6-vct" rows="2" placeholder="Ej: Sexo, semestre, estrato socioeconómico, jornada laboral" oninput="sf('m6-vct')"></textarea></div>
</div></div>
<div id="m6q" style="display:none">
<div class="al info"><div class="ali">&#128172;</div><div class="alc"><strong>En el enfoque cualitativo no se formulan hipótesis cerradas</strong>Las hipótesis presuponen relaciones que debes verificar estadísticamente. En cualitativo se trabaja con preguntas orientadoras y categorías apriorísticas.</div></div>
<div class="card"><div class="ct">Preguntas orientadoras</div><div class="fg"><label class="fl">Formula 3-5 preguntas que guíen la recolección e interpretación</label><div class="fh">No son las preguntas de la entrevista. Son preguntas teórico-metodológicas que orientan el análisis.</div><textarea id="m6-po" rows="4" placeholder="1. ¿Cómo describen los participantes su experiencia de...?&#10;2. ¿Qué significados atribuyen a...?&#10;3. ¿Qué estrategias han desarrollado para...?" oninput="sf('m6-po')"></textarea></div></div>
<div class="card"><div class="ct">Categorías apriorísticas</div><div class="fg"><label class="fl">¿Qué dimensiones conceptuales te llevas al campo?</label><textarea id="m6-cat" rows="3" placeholder="Ej: a) Significados del duelo, b) Estrategias de afrontamiento, c) Redes de apoyo, d) Trayectoria emocional..." oninput="sf('m6-cat')"></textarea></div><div class="al wn"><div class="ali">&#9888;&#65039;</div><div class="alc"><strong>Advertencia</strong>Las categorías apriorísticas orientan pero no deben cerrar la escucha. En el campo emergen categorías que no habías anticipado. Déjalas aparecer.</div></div></div>
</div>
<div class="card"><div class="ct">&#129302; Evaluar con IA</div><button class="btn bg bsm" onclick="genPM6()">Generar prompt de evaluación</button><div id="pm6" style="display:none;margin-top:12px"></div></div>
<div id="m6al"></div>
<div class="br brr"><button class="btn bs" onclick="goTPrev(6)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(6)">Siguiente &#8594; Diseño</button></div>
</div>

<!-- M7 DISEÑO -->
<div class="tp" id="panel-7">
<div class="ml">Módulo 7</div><h1 class="mt">Diseño de investigación</h1>
<p class="mi">El diseño establece cómo obtendrás los datos. Debe ser coherente con tu enfoque, alcance y los recursos disponibles.</p>
<div id="m7c" style="display:none">
<div class="card"><div class="ct">Tipo de diseño cuantitativo</div>
<div class="g2"><div class="fg"><label class="fl">¿Experimental o no experimental?</label><select id="m7-exp" onchange="sf('m7-exp');updM7()"><option value="">— Selecciona —</option><option value="experimental">Experimental (asignación aleatoria, manipulación de VI)</option><option value="cuasiexperimental">Cuasiexperimental (grupos preformados)</option><option value="no-experimental">No experimental (sin manipulación)</option></select></div>
<div class="fg"><label class="fl">Temporalidad</label><select id="m7-tem" onchange="sf('m7-tem')"><option value="">— Selecciona —</option><option value="transversal">Transversal (un solo momento)</option><option value="longitudinal">Longitudinal (varios momentos)</option><option value="longitudinal-panel">Longitudinal de panel (mismas personas)</option></select></div></div>
<div id="m7cd" style="margin-top:10px"></div></div>
</div>
<div id="m7q" style="display:none">
<div class="card"><div class="ct">Diseño cualitativo</div>
<div class="g2"><div class="fg"><label class="fl">Tipo de diseño</label><select id="m7-ct" onchange="sf('m7-ct');updM7Q()"><option value="">— Selecciona —</option><option value="emergente">Emergente (evoluciona en campo)</option><option value="instrumentado">Instrumentado (guiado por metodología específica)</option><option value="sistematico">Sistemático (más estructurado desde el inicio)</option></select></div>
<div class="fg"><label class="fl">Estrategia de muestreo</label><select id="m7-mu" onchange="sf('m7-mu')"><option value="">— Selecciona —</option><option value="intencional">Intencional / Propositivo</option><option value="teorico">Muestreo teórico (teoría fundamentada)</option><option value="saturacion">Por saturación</option><option value="bola-nieve">Bola de nieve</option><option value="maxima-variacion">Máxima variación</option></select></div></div>
<div id="m7qd" style="margin-top:10px"></div></div>
</div>
<div class="card"><div class="ct">Justifica tu diseño</div><div class="fg"><label class="fl">¿Por qué este diseño es el más apropiado para responder tu pregunta?</label><textarea id="m7-jus" rows="3" placeholder="Ej: Se optó por un diseño no experimental transversal porque es imposible manipular la VI éticamente, y el fenómeno se estudia en un momento específico sin seguimiento..." oninput="sf('m7-jus')"></textarea></div></div>
<div class="card"><div class="ct">Consideraciones éticas</div><div class="fg"><label class="fl">¿Qué consideraciones éticas tiene tu diseño?</label><textarea id="m7-eti" rows="3" placeholder="Ej: Se obtendrá consentimiento informado escrito. Los datos serán anonimizados. La participación es voluntaria. No hay riesgos físicos ni emocionales significativos." oninput="sf('m7-eti')"></textarea></div></div>
<div id="m7al"></div>
<div class="br brr"><button class="btn bs" onclick="goTPrev(7)">&#8592; Anterior</button><button class="btn bp blg" onclick="vanext(7)">Siguiente &#8594; Recolección</button></div>
</div>

<!-- M8 RECOLECCIÓN -->
<div class="tp" id="panel-8">
<div class="ml">Módulo 8</div><h1 class="mt">Recolección de datos</h1>
<p class="mi">Define quiénes serán tus participantes, con qué técnicas recolectarás información y cómo garantizarás la calidad de los datos.</p>
<div class="card"><div class="ct">Participantes</div>
<div class="fg"><label class="fl">Descripción de los participantes</label><textarea id="m8-par" rows="2" placeholder="Ej: Estudiantes universitarios de psicología, 18-30 años, matriculados en el semestre 2026-I en la UDEC Facatativá." oninput="sf('m8-par')"></textarea></div>
<div class="g2"><div class="fg"><label class="fl">Criterios de inclusión</label><textarea id="m8-inc" rows="3" placeholder="- Mayor de 18 años&#10;- Matriculado en la UDEC&#10;- Haber cursado al menos un semestre" oninput="sf('m8-inc')"></textarea></div>
<div class="fg"><label class="fl">Criterios de exclusión</label><textarea id="m8-exc" rows="3" placeholder="- Estudiantes en licencia académica&#10;- Diagnóstico previo de trastorno de ansiedad clínica" oninput="sf('m8-exc')"></textarea></div></div>
<div id="m8mc" style="display:none">
<div class="g2"><div class="fg"><label class="fl">Tipo de muestreo</label><select id="m8-tm" onchange="sf('m8-tm')"><option value="">— Selecciona —</option><option value="prob-aleatorio">Probabilístico aleatorio simple</option><option value="prob-estratificado">Probabilístico estratificado</option><option value="noprob-intencional">No probabilístico intencional</option><option value="noprob-conveniencia">No probabilístico por conveniencia</option></select></div>
<div class="fg"><label class="fl">Tamaño de muestra estimado</label><input type="text" id="m8-tam" placeholder="Ej: n=120 (G*Power α=.05 β=.80)" oninput="sf('m8-tam')"></div></div>
</div></div>
<div class="card"><div class="ct">Técnicas e instrumentos</div>
<div id="m8tc" style="display:none"><div class="fg"><label class="fl">Técnicas cuantitativas</label><div class="og">
<label class="oi"><input type="checkbox" id="m8-ens" onchange="sc('m8-ens')"><div class="ot"><div class="otn">Encuesta / cuestionario autoaplicado</div></div></label>
<label class="oi"><input type="checkbox" id="m8-esc" onchange="sc('m8-esc')"><div class="ot"><div class="otn">Escala psicométrica estandarizada</div></div></label>
<label class="oi"><input type="checkbox" id="m8-exp" onchange="sc('m8-exp')"><div class="ot"><div class="otn">Tarea experimental / prueba</div></div></label>
<label class="oi"><input type="checkbox" id="m8-obs" onchange="sc('m8-obs')"><div class="ot"><div class="otn">Observación sistemática</div></div></label>
</div></div></div>
<div id="m8tq" style="display:none"><div class="fg"><label class="fl">Técnicas cualitativas</label><div class="og">
<label class="oi"><input type="checkbox" id="m8-ent" onchange="sc('m8-ent')"><div class="ot"><div class="otn">Entrevista en profundidad semiestructurada</div></div></label>
<label class="oi"><input type="checkbox" id="m8-foc" onchange="sc('m8-foc')"><div class="ot"><div class="otn">Grupo de discusión / focal</div></div></label>
<label class="oi"><input type="checkbox" id="m8-obp" onchange="sc('m8-obp')"><div class="ot"><div class="otn">Observación participante</div></div></label>
<label class="oi"><input type="checkbox" id="m8-hiv" onchange="sc('m8-hiv')"><div class="ot"><div class="otn">Historia de vida / relato biográfico</div></div></label>
