/* === VALIDACIÓN === */
function runVal(n){
  const errs=[];
  if(n===1){
    if(!gv('m1-tema'))errs.push('Debes describir tu tema antes de continuar.');
    if(!gv('m1-preg'))errs.push('La pregunta de investigación es obligatoria.');
    else if(gv('m1-preg').length<20)errs.push('La pregunta parece demasiado corta. Amplía y delimita mejor.');
    if(!gv('m1-og'))errs.push('El objetivo general es obligatorio.');
  }
  if(n===2){if(!ST.enf)errs.push('Selecciona un enfoque.');if(!ST.par)errs.push('Selecciona el paradigma.');}
  if(n===3&&!ST.alc)errs.push('Selecciona el alcance de tu investigación.');
  if(n===4&&!ST.mc)errs.push('Selecciona la metodología cualitativa específica.');
  if(n===5&&!gv('m5-con'))errs.push('Registra al menos los conceptos clave de tu marco teórico.');
  if(n===8&&!gv('m8-par'))errs.push('Describe quiénes serán los participantes de tu estudio.');
  return errs;
}

