function buildCoh(){
  const e=ST.enf,p=ST.par;const issues=[],oks=[];
  if(e&&p){
    if(e==='cuanti'&&p==='interpretativo')issues.push('Tensión entre enfoque cuantitativo y paradigma interpretativo.');
    if(e==='cuali'&&p==='pospositivista')issues.push('Tensión entre enfoque cualitativo y paradigma positivista.');
    else oks.push('La combinación de enfoque y paradigma es coherente.');
  }
  if(e==='cuali'&&gv('m6-hip'))issues.push('Formulaste una hipótesis en un estudio cualitativo. El enfoque cualitativo no parte de hipótesis cerradas.');
  if((e==='cuanti'||e==='mixto')&&!gv('m6-hip')&&(ST.alc==='correlacional'||ST.alc==='explicativo'))issues.push(`El alcance ${ST.alc} requiere hipótesis formales que no están registradas.`);
  if(gv('m1-preg')&&gv('m1-og'))oks.push('Pregunta de investigación y objetivo general registrados.');
  if(!gv('m8-par'))issues.push('No has descrito los participantes del estudio.');
  if(gv('m5-con'))oks.push('El marco teórico tiene conceptos registrados.');
  const d=document.getElementById('cohrep');
  let html='<div class="card"><div class="ct">🔍 Reporte de coherencia</div>';
  if(oks.length)html+=mkAl('ok','✅','Aspectos coherentes',oks.map(o=>'• '+o).join('<br>'));
  if(issues.length)html+=mkAl('wn','⚠️','Tensiones detectadas',issues.map(i=>'• '+i).join('<br>'));
  if(!issues.length&&!oks.length)html+=mkAl('info','ℹ️','Sin datos suficientes','Completa más módulos para obtener un reporte de coherencia completo.');
  html+='</div>';d.innerHTML=html;
}

